000FFA 4FFA 10FB            13          djnz    .start
000FFC 4FFC C9              10          ret
                                
                                ; =====================================
                                ; 16bitを四桁の１６進数文字列に変換する
                                ; =====================================
                                ; @param BC value
                                ; @param HL dest ptr
       4FFD                     HEX16TOSTR:
       4FFD                         .start
000FFD 4FFD AF               4          xor     A
000FFE 4FFE 57               4          ld      D, A
                                
000FFF 4FFF CB08             8          rrc     B
001001 5001 CB08             8          rrc     B
001003 5003 CB08             8          rrc     B
001005 5005 CB08             8          rrc     B
001007 5007 78               4          ld      A, B
001008 5008 CD0F51          17          call    TOSTR_ONECONV
00100B 500B CB08             8          rrc     B
00100D 500D CB08             8          rrc     B
00100F 500F CB08             8          rrc     B
001011 5011 CB08             8          rrc     B
001013 5013 78               4          ld      A, B
001014 5014 CD0F51          17          call    TOSTR_ONECONV
001017 5017 CB09             8          rrc     C
001019 5019 CB09             8          rrc     C
00101B 501B CB09             8          rrc     C
00101D 501D CB09             8          rrc     C
00101F 501F 79               4          ld      A, C
001020 5020 CD0F51          17          call    TOSTR_ONECONV
001023 5023 CB09             8          rrc     C
001025 5025 CB09             8          rrc     C
001027 5027 CB09             8          rrc     C
001029 5029 CB09             8          rrc     C
00102B 502B 79               4          ld      A, C
00102C 502C CD0F51          17          call    TOSTR_ONECONV
00102F 502F 72               7          ld      (HL), D     ;; '\0'
001030 5030 C9              10          ret
                                
                                ; =====================================
                                ; 二桁の１０進数文字列に変換する（00形式)
                                ; =====================================
                                ; @param A value(0-99)
                                ; @param HL dest ptr
       5031                     DEC2TOSTR:
       5031                         .start
001031 5031 C5              11          push    BC
001032 5032 01000A          10          ld      BC, 0x0a00
001035 5035 CD2553          17          call    DIV8R           ; C=十の位、A=一の位
001038 5038 47               4          ld      B, A
001039 5039 3E30             7          ld      A, '0'
00103B 503B 81               4          add     A, C
00103C 503C 77               7          ld      (HL), A
00103D 503D 23               6          inc     HL
00103E 503E 3E30             7          ld      A, '0'
001040 5040 80               4          add     A, B
001041 5041 77               7          ld      (HL), A
001042 5042 23               6          inc     HL
                                        ; 終端'\0'
001043 5043 AF               4          xor     A
001044 5044 77               7          ld      (HL), A
001045 5045 C1              10          pop     BC
001046 5046 C9              10          ret
                                
                                ; =====================================
                                ; 三桁の１０進数文字列に変換する（0-255→000形式)
                                ; =====================================
                                ; @param A value(0-255)
                                ; @param HL dest ptr
       5047                     DEC3TOSTR:
       5047                         .start
001047 5047 C5              11          push    BC
                                    ;
001048 5048 010064          10          ld      BC, 0x6400      ; A/100 → C=百の位、A=あまり（100未満の値）
00104B 504B CD2553          17          call    DIV8R
00104E 504E 47               4          ld      B, A
00104F 504F 3E30             7          ld      A, '0'
001051 5051 81               4          add     A, C
001052 5052 77               7          ld      (HL), A
001053 5053 23               6          inc     HL
001054 5054 78               4          ld      A, B
                                    ;
001055 5055 01000A          10          ld      BC, 0x0a00      ; A/10 → C=十の位、A=一の位
001058 5058 CD2553          17          call    DIV8R
00105B 505B 47               4          ld      B, A
00105C 505C 3E30             7          ld      A, '0'
00105E 505E 81               4          add     A, C
00105F 505F 77               7          ld      (HL), A
001060 5060 23               6          inc     HL
001061 5061 3E30             7          ld      A, '0'
001063 5063 80               4          add     A, B
001064 5064 77               7          ld      (HL), A
001065 5065 23               6          inc     HL
                                    ; 終端'\0'
001066 5066 AF               4          xor     A
001067 5067 77               7          ld      (HL), A
                                    ;
001068 5068 C1              10          pop     BC
001069 5069 C9              10          ret
                                
                                ; =====================================
                                ; 三桁の１０進数文字列に変換する（0-999→000形式)
                                ; =====================================
                                ; @param DE value(0-999) ※1000以上はNG
                                ; @param HL dest ptr
                                
       506A                     DEC3TOSTR999:
       506A                         .start
00106A 506A 7A               4          ld      A, D
00106B 506B B7               4          or      A
00106C 506C 2022            12          jr      nz, .over999     ; 念のため（999 超えは処理しない）
                                
                                        ; --- 百の位を求める ---
00106E 506E 7B               4          ld      A,E
00106F 506F FE64             7          cp      100
001071 5071 3806            12          jr      c,.less100
001073 5073 D664             7          sub     100
001075 5075 0631             7          ld      B,'1'
001077 5077 1802            12          jr      .got_hund
       5079                         .less100
001079 5079 0630             7          ld      B,'0'
       507B                         .got_hund
00107B 507B 70               7          ld      (HL),B
00107C 507C 23               6          inc     HL
                                
                                        ; --- 十の位を求める ---
00107D 507D 0630             7          ld      B,'0'
       507F                         .ten_loop
00107F 507F FE0A             7          cp      10
001081 5081 3805            12          jr      c,.ten_done
001083 5083 D60A             7          sub     10
001085 5085 04               4          inc     B
001086 5086 18F7            12          jr      .ten_loop
       5088                         .ten_done
001088 5088 70               7          ld      (HL),B
001089 5089 23               6          inc     HL
                                
                                        ; --- 一の位 ---
00108A 508A C630             7          add     A,'0'
00108C 508C 77               7          ld      (HL),A
00108D 508D 1809            12              jr      .terminator
00108F 508F C9              10          ret
       5090                         .over999
                                        ; 999 超えは "999" を返す
001090 5090 3639            10          ld      (HL),'9'
001092 5092 23               6          inc     HL
001093 5093 3639            10          ld      (HL),'9'
001095 5095 23               6          inc     HL
001096 5096 3639            10          ld      (HL),'9'
       5098                         .terminator
001098 5098 23               6          inc     HL
001099 5099 AF               4          xor     A
00109A 509A 77               7          ld      (HL),A
00109B 509B C9              10          ret
                                
                                ; =====================================
                                ; 5桁の10進数文字列に変換する（0-65535 → 00000形式）
                                ; =====================================
                                ; @param DE  value (0-65535)
                                ; @param HL  dest ptr ("00000",0 の 6バイト)
                                ; =====================================
                                
       509C                         DEC5TOSTR65535:
       509C                         .start
00109C 509C E5              11          push    HL
                                        ; 値を HL に、出力ポインタを DE に退避
00109D 509D EB               4          ex      DE,HL          ; HL = value, DE = dest
                                
                                        ; --- 10000 の位 ---
00109E 509E 011027          10          ld      BC,10000
0010A1 50A1 3E30             7          ld      A,'0'
       50A3                         .dig10000
0010A3 50A3 B7               4          or      A              ; C=0
0010A4 50A4 ED42            15          sbc     HL,BC          ; HL -= 10000
0010A6 50A6 3803            12          jr      c,.done10000
0010A8 50A8 3C               4          inc     A              ; digit++
0010A9 50A9 18F8            12          jr      .dig10000
       50AB                         .done10000
0010AB 50AB 09              11          add     HL,BC          ; 負になった分を戻す → remainder
0010AC 50AC 12               7          ld      (DE),A
0010AD 50AD 13               6          inc     DE
                                
                                        ; --- 1000 の位 ---
0010AE 50AE 01E803          10          ld      BC,1000
0010B1 50B1 3E30             7          ld      A,'0'
       50B3                         .dig1000
0010B3 50B3 B7               4          or      A
0010B4 50B4 ED42            15          sbc     HL,BC
0010B6 50B6 3803            12          jr      c,.done1000
0010B8 50B8 3C               4          inc     A
0010B9 50B9 18F8            12          jr      .dig1000
       50BB                         .done1000
0010BB 50BB 09              11          add     HL,BC
0010BC 50BC 12               7          ld      (DE),A
0010BD 50BD 13               6          inc     DE
                                
                                        ; --- 100 の位 ---
0010BE 50BE 016400          10          ld      BC,100
0010C1 50C1 3E30             7          ld      A,'0'
       50C3                         .dig100
0010C3 50C3 B7               4          or      A
0010C4 50C4 ED42            15          sbc     HL,BC
0010C6 50C6 3803            12          jr      c,.done100
0010C8 50C8 3C               4          inc     A
0010C9 50C9 18F8            12          jr      .dig100
       50CB                         .done100
0010CB 50CB 09              11          add     HL,BC
0010CC 50CC 12               7          ld      (DE),A
0010CD 50CD 13               6          inc     DE
                                
                                        ; --- 10 の位 ---
0010CE 50CE 010A00          10          ld      BC,10
0010D1 50D1 3E30             7          ld      A,'0'
       50D3                         .dig10
0010D3 50D3 B7               4          or      A
0010D4 50D4 ED42            15          sbc     HL,BC
0010D6 50D6 3803            12          jr      c,.done10
0010D8 50D8 3C               4          inc     A
0010D9 50D9 18F8            12          jr      .dig10
       50DB                         .done10
0010DB 50DB 09              11          add     HL,BC
0010DC 50DC 12               7          ld      (DE),A
0010DD 50DD 13               6          inc     DE
                                
                                        ; --- 1 の位（ここで HL < 10 が保証されている） ---
0010DE 50DE 7D               4          ld      A,L
0010DF 50DF C630             7          add     A,'0'
0010E1 50E1 12               7          ld      (DE),A
0010E2 50E2 13               6          inc     DE
                                
                                        ; --- 終端 ---
0010E3 50E3 AF               4          xor     A
0010E4 50E4 12               7          ld      (DE),A
                                
                                        ; delete '0'prefix
0010E5 50E5 0604             7          ld      B,4
0010E7 50E7 E1              10          pop     HL
       50E8                         .@@
0010E8 50E8 7E               7          ld      A,(HL)
0010E9 50E9 FE30             7          cp      '0'
0010EB 50EB 2005            12          jr      nz,.finish
0010ED 50ED 3620            10          ld      (HL),' '
0010EF 50EF 23               6          inc     HL
0010F0 50F0 10F6            13          djnz    .@@B
       50F2                         .finish
0010F2 50F2 C9              10          ret
                                
                                
                                ; =====================================
                                ; 8bitを二桁の１６進数文字列に変換する
                                ; =====================================
                                ; @param B value
                                ; @param HL dest ptr
                                ; @note use DE,HL,IX
       50F3                     HEX8TOSTR:
       50F3                         .start
0010F3 50F3 AF               4          xor     A
