                                ;*** AILZ80ASM *** Z-80 Assembler, version 1.0.31.0, LST:Full:4
                                ; @title CT-ARK2 Menu.
                                ; @auther Harumakkin
                                
                                ; bios
       000C                     B_RDSLT             equ 0x000C  ;; BIOS: 指定スロットの指定アドレスの値を読みだす A=スロット、HL=アドレス、変更レジスタAF、BC、DE
       0014                     B_WRSLT             equ 0x0014  ;; BIOS: 指定スロットの指定アドレスへ値を書き込む A=スロット、HL=アドレス、E=値、変更レジスタAF,BC,D
       0024                     B_ENASLT            equ 0x0024  ;; BIOS: 指定ページを指定スロットに切り替える
       00C3                     B_CLS               equ 0x00C3  ;; BIOS: 画面クリア 入力=ゼロフラグセット
       00A2                     B_CHPUT             equ 0x00A2  ;; BIOS: 1文字表示 入力A=出力する文字コード
       009F                     B_CHGET             equ 0x009F  ;; BIOS: 1文字入力 (入力待ちあり), 出力A=入力された文字コード
       00C6                     B_POSIT             equ 0x00C6  ;; BIOS: カーソルの移動, 入力H=カーソルのX座標, L=Y座標
       0156                     B_KILBUF            equ 0x0156  ;; BIOS: キーバッファのクリア
       00C0                     B_BEEP              equ 0x00C0  ;; BIOS: BEEP音を鳴らす（全レジスタ使用）
       0180                     B_CHGCPU            equ 0x0180  ;; BIOD: CPU切り換え
       005C                     B_LDIRVM            equ 0x005C  ;; BIOS; メモリからVRAMヘデータをブロック転送する
                                
                                ; system's workarea
       FC9E                     W_JIFFY             equ 0xFC9E  ;; 
       002D                     MAINROMVER          equ 0x002D  ;; MAIN ROM Version, 0=MSX, 1=MSX2, 2=MSX2+, 3=MSXtR
                                
                                ; keycode
       001E                     KEY_UP              equ 0x1E
       001C                     KEY_RIGHT           equ 0x1C
       001D                     KEY_LEFT            equ 0x1D
       001F                     KEY_DOWN            equ 0x1F
       001B                     KEY_ESC             equ 0x1B
       000B                     KEY_CLS             equ 0x0B
       000D                     KEY_RETURN          equ 0x0D
       0009                     KEY_TAB             equ 0x09
       0008                     KEY_BS              equ 0x08
       007F                     KEY_DEL             equ 0x7f
                                
                                ; command
       0000                     IFCMD:
       0000                         .NONE               equ 0x00
       0001                         .UPDATE_INFO        equ 0x01
       0002                         .UPDATE_FILELIST    equ 0x02
       0003                         .REQ_FILELIST       equ 0x03
       0004                         .SET_ROM            equ 0x04
       0005                         .DEL_ROMFILE        equ 0x05
       0006                         .WR_FILE            equ 0x06
       0007                         .BAS2ROM            equ 0x07
       0008                         .STORE_ROM          equ 0x08
       0009                         .SET_FREQ           equ 0x09
       000A                         .CLEAR_E_PAPER      equ 0x0A
       000B                         .PRINT_E_PAPER      equ 0x0B
                                
       0012                     SIZE_FILERECORD     equ 18      ; sizeof(MSXPICOIF_FILERECORD)
                                
       0000                     SETROMTYPE:
       0030                         .NONE               equ '0'
       0031                         .CTARKMENU          equ '1'
       0032                         .MAPPERERAM         equ '2'
       0061                         .ROM_PAGE_0         equ 'a' ; ROMTYPEというより格納先頭ページは何かを示している。
       0062                         .ROM_PAGE_1         equ 'b' ; 占有する領域サイズは、指定したファイルサイズで決まる。
       0063                         .ROM_PAGE_2         equ 'c' ; PAGE0を選択しても対象ファイルが16KBならPAGE0で収まるし、
       0064                         .ROM_PAGE_3         equ 'd' ; 64KBなら、PAGE0-3を占有する。
       0065                         .MSXDOS2_320KB      equ 'e' ; PICO RAM上でASCII8Kの動作
       0066                         .ASC8K_RAM          equ 'f' ; PICO RAM上での動作
       0067                         .ASC16K_RAM         equ 'g' ; PICO RAM上でASCII16Kの動作
       0068                         .ASC8K_FLASHROM     equ 'h' ; PICO FlushROM上でASCII8Kの動作（384KB以下の場合ははRAM動作になる）
       0069                         .ASC16K_FLASHROM    equ 'i' ; PICO FlushROM上でASCII16Kの動作（384KB以下の場合ははRAM動作になる）
       006A                         .NEXTOR128KB_256KB  equ 'j' ; NEXTORカーネル128KB + MapperRAM(256KB)
       006B                         .RTYPE              equ 'k' ; ASCII16K(RTYPE)
                                    ; .KONAMI8K         equ '?'
                                    ; .KONAMISCC        equ '?'
                                    ; .KONAMISCCI       equ '?'
                                
                                ;選択カーソル文字
       0021                     CURSOR_CHAR         equ 0x21
       0022                     ARROW_CHAR          equ 0x22
       0020                     BLANK_CHAR          equ ' '
                                
                                
                                ;================================================================================================
                                ; MSX ROMヘッダ領域
                                ;================================================================================================
000000 4000                     org 0x4000
       4000                     rom_header:
000000 4000 4142                    db      "AB"
000002 4002 8A41                    dw      START_CT_ARK        ;; INIT
000004 4004 0000                    dw      0x0000              ;; STATEMENT
000006 4006 0000                    dw      0x0000              ;; DEVICE
000008 4008 0000                    dw      0x0000              ;; TEXT
00000A 400A 000000                  db      0x00,0x00,0x00
00000D 400D 000000                  db      0x00,0x00,0x00
                                
                                
                                ;================================================================================================
                                ;================================================================================================
                                
                                ; 右向き三角、右向き矢印文字を作成する
                                ; グラフィック文字 "月","火"を、右向き三角、右向き矢印とする
       4010                     CHARACTERS:
       4010                         .setup
000010 4010 211D40          10          ld      HL, .patterns
000013 4013 110809          10          ld      DE, 0x800 + 8*0x21
000016 4016 011000          10          ld      BC, 8 * 2
000019 4019 CD5C00          17          call    B_LDIRVM
00001C 401C C9              10          ret
       401D                         .patterns
00001D 401D 4060707878706040            db      0x40,0x60,0x70,0x78,0x78,0x70,0x60,0x40
000025 4025 2030F8FCFCF83020            db      0x20,0x30,0xF8,0xFC,0xFC,0xF8,0x30,0x20
                                
       402D                     CTXT:
       0000                         .endc           equ 0x00
       0001                         .fill           equ 0x01    ;; スクリーン全体の塗りつぶし
       0002                         .prints         equ 0x02    ;; 文字列を描く
       0003                         .prints_ptr     equ 0x03    ;; 文字列を描く(文字列はポインタ指定)
       0004                         .chars          equ 0x04    ;; 指定文字を指定数繰り返す
       0005                         .box            equ 0x05    ;; 矩形
       0006                         .boxseph        equ 0x06    ;; 矩形の区切線(水平)
       0007                         .present        equ 0x07    ;; VRAMへ反映
                                    ;
       00FF                         .EOT            equ 0xff    ;; .printsでの終端を示す
                                    ;
       0028                         .SCR_W          equ 40
       0018                         .SCR_H          equ 24
       03C0                         .SCR_SIZE       equ 960     ;; 40*24
                                
       402D                     CTXTF:
       402D                         .xy2addr
                                    ; @param reg.DE :X,Y
                                    ; @return reg.HL :先頭アドレス
00002D 402D D5              11          push    DE
00002E 402E 3E28             7          ld      A, CTXT.SCR_W
000030 4030 CD1353          17          call    MULTI8X8R16     ; HL = A*E;
000033 4033 D1              10          pop     DE
000034 4034 5A               4          ld      E, D
000035 4035 1600             7          ld      D, 0x00
000037 4037 19              11          add     HL, DE          ; 先頭アドレス
000038 4038 11005A          10          ld      DE, CTXTB.buff
00003B 403B 19              11          add     HL, DE
00003C 403C C9              10          ret
                                
                                    ;----------------------------------------------------------
       403D                         .buff_fill
                                    ; 画面バッファのクリア(塗りつぶし)
                                    ; @param reg.A:塗りつぶすキャラクタ文字
00003D 403D 21005A          10          ld      HL, CTXTB.buff
000040 4040 11015A          10          ld      DE, CTXTB.buff+1
000043 4043 01BF03          10          ld      BC, CTXT.SCR_SIZE-1
000046 4046 77               7          ld      (HL), A
000047 4047 EDB0                        ldir
000049 4049 C9              10          ret
                                    ;----------------------------------------------------------
       404A                         .buff_print
                                    ; 画面バッファの指定位置に文字列を書き込む
                                    ; @param reg.DE :X,Y
                                    ; @param reg.HL :文字列へのポインタ(0x00終端)
                                    ; @return reg.HL :文字列の終端の次を示すポインタ
00004A 404A E5              11          push    HL
00004B 404B CD2D40          17          call    .xy2addr        ; HL=先頭アドレス
00004E 404E 54               4          ld      D, H
00004F 404F 5D               4          ld      E, L
000050 4050 E1              10          pop     HL
       4051                         .@@
000051 4051 7E               7          ld      A, (HL)
000052 4052 B7               4          or      A
000053 4053 2805            12          jr      z, .@@F
000055 4055 12               7          ld      (DE), A
000056 4056 23               6          inc     HL
000057 4057 13               6          inc     DE
000058 4058 18F7            12          jr      .@@B
       405A                         .@@
00005A 405A 23               6          inc     HL
00005B 405B C9              10          ret
                                    ;----------------------------------------------------------
       405C                         .buff_put_char
                                    ; 画面バッファの指定位置に指定キャラクタを書き込む
                                    ; @param reg.DE :X,Y
                                    ; @param reg.A :キャラクタ文字
00005C 405C F5              11          push    AF
00005D 405D CD2D40          17          call    .xy2addr        ; HL=先頭アドレス
000060 4060 F1              10          pop     AF
       4061                         .@@
000061 4061 77               7          ld      (HL), A
000062 4062 C9              10          ret
                                
                                    ;----------------------------------------------------------
       4063                         .buff_chars
                                    ; 画面バッファの指定位置から指定のキャラクタで塗りつぶし
                                    ; @param reg.DE :X,Y
                                    ; @param reg.A :塗つぶしキャラクタ文字
                                    ; @param reg.B :塗りつぶす文字数
000063 4063 48               4          ld      C, B
000064 4064 F5              11          push    AF
000065 4065 CD2D40          17          call    .xy2addr        ; HL=先頭アドレス
000068 4068 41               4          ld      B, C
000069 4069 F1              10          pop     AF
       406A                         .@@
00006A 406A 77               7          ld      (HL), A
00006B 406B 23               6          inc     HL
00006C 406C 10FC            13          djnz    .@@B
00006E 406E C9              10          ret
                                    ;----------------------------------------------------------
       406F                         .buff_box
                                    ; 画面バッファの指定位置に矩形を書き込む(矩形内は0x20の空白)
                                    ; @param reg.DE :X,Y
                                    ; @param reg.BC :lenX, lenY  角は含まない長さであり、必ず1以上を指定する  ┏━┓の場合は、lenX=1である。
00006F 406F C5              11          push    BC
000070 4070 CD2D40          17          call    .xy2addr        ; HL=先頭アドレス
                                        ; "┏"
000073 4073 3E18             7          ld      A, 0x18
000075 4075 77               7          ld      (HL),A
                                        ; "━"
000076 4076 3E17             7          ld      A, 0x17
000078 4078 C1              10          pop     BC
000079 4079 E5              11          push    HL
00007A 407A C5              11          push    BC
       407B                         .@1
00007B 407B 23               6          inc     HL
00007C 407C 77               7          ld      (HL),A
00007D 407D 10FC            13          djnz    .@1
                                        ; "┓"
00007F 407F 23               6          inc     HL
000080 4080 3E19             7          ld      A, 0x19
000082 4082 77               7          ld      (HL),A
000083 4083 C1              10          pop     BC
000084 4084 E1              10          pop     HL
       4085                         .@2
000085 4085 112800          10          ld      DE, CTXT.SCR_W  ; to next line.
000088 4088 19              11          add     HL, DE
000089 4089 E5              11          push    HL
00008A 408A C5              11          push    BC
                                        ; "┃"
00008B 408B 3E16             7          ld      A, 0x16
00008D 408D 77               7          ld      (HL), A
                                        ; " "
00008E 408E 3E20             7          ld      A, ' '
       4090                         .@3
000090 4090 23               6          inc     HL
000091 4091 77               7          ld      (HL), A
000092 4092 10FC            13          djnz    .@3
                                        ; "┃"
000094 4094 23               6          inc     HL
000095 4095 3E16             7          ld      A, 0x16
000097 4097 77               7          ld      (HL), A
000098 4098 C1              10          pop     BC
000099 4099 79               4          ld      A, C
00009A 409A 3D               4          dec     A
00009B 409B 4F               4          ld      C, A
00009C 409C E1              10          pop     HL
00009D 409D 20E6            12          jr      nz, .@2
                                        ;
00009F 409F 112800          10          ld      DE, CTXT.SCR_W  ; to next line.
0000A2 40A2 19              11          add     HL, DE
                                        ; "┗"
0000A3 40A3 3E1A             7          ld      A, 0x1A
0000A5 40A5 77               7          ld      (HL),A
                                        ; "━"
0000A6 40A6 3E17             7          ld      A, 0x17
       40A8                         .@4
0000A8 40A8 23               6          inc     HL
0000A9 40A9 77               7          ld      (HL),A
0000AA 40AA 10FC            13          djnz    .@4
                                        ; "┛"
0000AC 40AC 23               6          inc     HL
0000AD 40AD 3E1B             7          ld      A, 0x1B
0000AF 40AF 77               7          ld      (HL),A
0000B0 40B0 C9              10          ret
                                    ;----------------------------------------------------------
       40B1                         .buff_boxseph
                                    ; 画面バッファの指定位置に矩形用のセパレータ線（┣━┫）を書き込む（┣━┫）
                                    ; @param reg.DE :開始点座標 X,Y
                                    ; @param reg.B :端含まない長さであり、必ず1以上を指定する  ex)┣━━━┫では、lenX=3である。
                                    ;
0000B1 40B1 C5              11          push    BC
0000B2 40B2 CD2D40          17          call    .xy2addr        ; HL=先頭アドレス
                                        ; "┣"
0000B5 40B5 3E14             7          ld      A, 0x14
0000B7 40B7 77               7          ld      (HL),A
                                        ; "━"
0000B8 40B8 3E17             7          ld      A, 0x17
0000BA 40BA C1              10          pop     BC
       40BB                         .@1
0000BB 40BB 23               6          inc     HL
0000BC 40BC 77               7          ld      (HL),A
0000BD 40BD 10FC            13          djnz    .@1
                                        ; "┫"
0000BF 40BF 23               6          inc     HL
0000C0 40C0 3E13             7          ld      A, 0x13
0000C2 40C2 77               7          ld      (HL),A
0000C3 40C3 C9              10          ret
                                
                                    ;----------------------------------------------------------
                                    ; BCレジスタの値を4桁の16進数に変換して書き込む
       40C4                         .buff_print4hex
                                    ; @param reg.BC :16ビット値
                                    ; @param reg.DE :座標 X,Y
                                    ;
0000C4 40C4 C5              11          push    BC
0000C5 40C5 CD2D40          17          call    .xy2addr        ; HL=先頭アドレス <- DE:座標
0000C8 40C8 C1              10          pop     BC
0000C9 40C9 CDFD4F          17          call    HEX16TOSTR      ; AF,BC,DE,HL,IX
0000CC 40CC C9              10          ret
                                
                                    ;----------------------------------------------------------
       40CD                         .buff_present
                                    ; メインメモリ内のスクリーンバッファの内容をVRAMへ転送する
0000CD 40CD 21005A          10          ld      HL, CTXTB.buff
0000D0 40D0 110000          10          ld      DE, 0x0000
0000D3 40D3 01C003          10          ld      BC, CTXT.SCR_SIZE
0000D6 40D6 CD5C00          17          call    B_LDIRVM
0000D9 40D9 C9              10          ret
                                
                                    ;----------------------------------------------------------
       40DA                         .buff_present_backroll
                                    ; メインメモリ内のスクリーンバッファの内容をVRAMへ転送する
                                    ; (画面下方から上に向かって転送する)
0000DA 40DA DD219EFC        14          ld      IX, W_JIFFY
0000DE 40DE DD4E00          19          ld      C, (IX+0)
0000E1 40E1 21985D          10          ld      HL, CTXTB.buff + (CTXT.SCR_H-1)*CTXT.SCR_W
0000E4 40E4 119803          10          ld      DE, (CTXT.SCR_H-1)*CTXT.SCR_W
0000E7 40E7 060C             7          ld      B, CTXT.SCR_H/2
       40E9                         .@1
0000E9 40E9 C5              11          push    BC
0000EA 40EA CDFD40          17          call    .@3
0000ED 40ED CDFD40          17          call    .@3
0000F0 40F0 C1              10          pop     BC
0000F1 40F1 79               4          ld      A, C
       40F2                         .@2
0000F2 40F2 DDBE00          19          cp      (IX+0)
0000F5 40F5 28FB            12          jr      z, .@2
0000F7 40F7 DD4E00          19          ld      C, (IX+0)
0000FA 40FA 10ED            13          djnz    .@1
0000FC 40FC C9              10          ret
       40FD                         .@3
0000FD 40FD E5              11          push    HL
0000FE 40FE D5              11          push    DE
0000FF 40FF 012800          10          ld      BC, CTXT.SCR_W
000102 4102 CD5C00          17          call    B_LDIRVM
000105 4105 E1              10          pop     HL
000106 4106 112800          10          ld      DE, CTXT.SCR_W
000109 4109 CD5353          17          call    SUB_HL_DE
00010C 410C 44               4          ld      B, H
00010D 410D 4D               4          ld      C, L
00010E 410E E1              10          pop     HL
00010F 410F CD5353          17          call    SUB_HL_DE
000112 4112 50               4          ld      D, B
000113 4113 59               4          ld      E, C
000114 4114 C9              10          ret
                                
                                    ;----------------------------------------------------------
       4115                         .go_scr
                                    ; 指定した.DESGINデータをもとにスクリーンを描く
                                    ; 温メモリ上に描き、.printsでVRAMに転送される
                                    ; @param reg.HL .DESGINデータの先頭アドレス
                                    ;
       4115                         .@@
000115 4115 7E               7          ld      A, (HL)
000116 4116 F5              11          push    AF
000117 4117 23               6          inc     HL
                                        ;call act_func_table's routines!
000118 4118 CD2041          17          call    .call_act_func
00011B 411B F1              10          pop     AF
00011C 411C B7               4          or      A
00011D 411D 20F6            12          jr      nz, .@@B        ; 次のコマンドへ
00011F 411F C9              10          ret
                                
       4120                         .call_act_func
000120 4120 E5              11          push    HL
000121 4121 6F               4          ld      L,A                 ; A → L
000122 4122 2600             7          ld      H,0                 ; HL = A
000124 4124 29              11          add     HL,HL               ; HL = A * 2（アドレスは2バイトなので×2）
000125 4125 112F41          10          ld      DE,.act_func_table  ; DE = テーブル先頭
000128 4128 19              11          add     HL,DE               ; HL = Table + A*2
000129 4129 5E               7          ld      E,(HL)              ; 低位バイト
00012A 412A 23               6          inc     HL
00012B 412B 56               7          ld      D,(HL)              ; 高位バイト → DE = サブルーチン先頭アドレス
00012C 412C E1              10          pop     HL
00012D 412D D5              11          push    DE
00012E 412E C9              10          ret                         ; = CALL (DE)   サブルーチン先で.call_act_funcの呼び出しもとに帰る仕組み。
                                
       412F                         .act_func_table
00012F 412F 3F41                        dw  .act_endc       ;; .endc        
000131 4131 4041                        dw  .act_fill       ;; .fill        ;; クリア
000133 4133 4841                        dw  .act_prints     ;; .prints      ;; 文字列を描く
000135 4135 5B41                        dw  .act_prints_ptr ;; .prints_ptr  ;; ポインタで指定された文字列を描く
000137 4137 5C41                        dw  .act_chars      ;; .chars       ;; 指定文字を指定数繰り返す
000139 4139 6A41                        dw  .act_box        ;; .box         ;; 矩形
00013B 413B 7841                        dw  .act_boxseph    ;; .boxseph     ;; 矩形の区切線(水平)
00013D 413D 8441                        dw  .act_present    ;; .present     ;; VRAMへ反映
                                
       413F                         .act_endc
                                        ; do nothing
00013F 413F C9              10          ret
                                
       4140                         .act_fill
000140 4140 7E               7          ld      A, (HL)
000141 4141 23               6          inc     HL
000142 4142 E5              11          push    HL
000143 4143 CD3D40          17          call    .buff_fill
000146 4146 E1              10          pop     HL
000147 4147 C9              10          ret
                                
       4148                         .act_prints
000148 4148 5E               7          ld      E, (HL)
000149 4149 23               6          inc     HL
00014A 414A 56               7          ld      D, (HL)
00014B 414B 23               6          inc     HL
       414C                         .@@
00014C 414C D5              11          push    DE
00014D 414D CD4A40          17          call    CTXTF.buff_print
000150 4150 D1              10          pop     DE
000151 4151 7E               7          ld      A, (HL)
000152 4152 FEFF             7          cp      CTXT.EOT        ; 終端だったら終了する
000154 4154 2803            12          jr      z, .@@F
000156 4156 1C               4          inc     E               ; 次の行
000157 4157 18F3            12          jr      .@@B
       4159                         .@@
000159 4159 23               6          inc     HL
00015A 415A C9              10          ret
                                
       415B                         .act_prints_ptr
                                        ; TODO: 未コーディング
                                        ;       座標を読む
                                        ;       アドレスポインタを読む
                                        ;       アドレスポインタが示す文字列を使用する
                                        ;       （文字列が格納されているのではなく、アドレスが格納されているところが.act_printsと異なる。
                                        ;       これにより定型句などの文字列の使いまわしを可能にし、メモリの無駄を省く)
00015B 415B C9              10          ret
                                
       415C                         .act_chars
00015C 415C 5E               7          ld      E, (HL)
00015D 415D 23               6          inc     HL
00015E 415E 56               7          ld      D, (HL)
00015F 415F 23               6          inc     HL
000160 4160 7E               7          ld      A, (HL)
000161 4161 23               6          inc     HL
000162 4162 46               7          ld      B, (HL)
000163 4163 23               6          inc     HL
000164 4164 E5              11          push    HL
000165 4165 CD6340          17          call    .buff_chars
000168 4168 E1              10          pop     HL
000169 4169 C9              10          ret
                                
       416A                         .act_box
00016A 416A 5E               7          ld      E, (HL)
00016B 416B 23               6          inc     HL
00016C 416C 56               7          ld      D, (HL)
00016D 416D 23               6          inc     HL
00016E 416E 4E               7          ld      C, (HL)
00016F 416F 23               6          inc     HL
000170 4170 46               7          ld      B, (HL)
000171 4171 23               6          inc     HL
000172 4172 E5              11          push    HL
000173 4173 CD6F40          17          call    .buff_box
000176 4176 E1              10          pop     HL
000177 4177 C9              10          ret
                                
       4178                         .act_boxseph
000178 4178 5E               7          ld      E, (HL)
000179 4179 23               6          inc     HL
00017A 417A 56               7          ld      D, (HL)
00017B 417B 23               6          inc     HL
00017C 417C 46               7          ld      B, (HL)
