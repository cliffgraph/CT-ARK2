                                ;=========================================
       4480                     FUNC_CMD_TO_CTARK:
                                    ;   A=CMD
                                    ;   B=CMD_VALUE
       4480                         .start
000480 4480 4F               4          ld      C, A
000481 4481 AF               4          xor     A
000482 4482 32255F          13          ld      (MSXPICO_IF.cmd_res), A
000485 4485 78               4          ld      A, B
000486 4486 32275F          13          ld      (MSXPICO_IF_BASE.cmd_value), A
000489 4489 79               4          ld      A, C
00048A 448A 32265F          13          ld      (MSXPICO_IF_BASE.code), A
                                
       448D                         .wait_res
00048D 448D 3A255F          13          ld      A, (MSXPICO_IF.cmd_res)
000490 4490 B9               4          cp      C
000491 4491 20FA            12          jr      nz, .wait_res
                                
000493 4493 C9              10          ret 
                                
