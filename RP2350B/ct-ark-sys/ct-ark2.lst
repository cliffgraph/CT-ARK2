                                        ; -----------------------------------------------------------------
                                        ; 基本スロットを一時的に「元のスロット」に戻さないと、
                                        ; 元の拡張スロットレジスタ(0xFFFF)にアクセスできないため、先に基本を戻す
001404 5404 78               4          ld      A, B
001405 5405 D3A8            11          out     (0xA8), A
                                
                                        ; 拡張スロットだった場合、まず拡張スロットレジスタを元に戻す
001407 5407 79               4          ld      A, C
001408 5408 07               4          rlca                        ; 元のスロットが拡張だったかチェック
001409 5409 3006            12          jr      nc, .finish
                                
                                        ; 元の拡張スロットレジスタの値を書き戻す
00140B 540B 7A               4          ld      A, D
00140C 540C 32FFFF          13          ld      (0xFFFF), A
00140F 540F 1800            12          jr      .finish
                                
       5411                         .finish
001411 5411 7B               4          ld      A, E           ; 退避していた読み込みデータを A レジスタに戻す
001412 5412 D1              10          pop     DE             ; レジスタの復帰
001413 5413 C1              10          pop     BC
001414 5414 C9              10          ret
                                
                                ;----------------------------------------------------------------------
       5415                     WA_SLT2_P3:
       5415                         .local_W_EXPTBL2
001415 5415 01                          db      1
       5416                         .local_W_SLTTBL2
001416 5416 01                          db      1
[EOF:tools.z80:UTF_8]
                                include "flashrom.z80"
                                ; MSX用カートリッジ64K Simple ROM Cartridge 
                                ; SST39SF010A
                                ; https://github.com/v9938/MSX_SimpleCartridge
                                ; https://www.kadenken.com/view/item/000000001288
                                
                                ; B_RDSLT               equ 0x000C
                                ; B_WRSLT               equ 0x0014
                                ; W_JIFFY               equ 0xFC9E
                                
                                ;====================================================
                                ; Reset FlashROM
                                ;====================================================
       5417                     SST39SF010A_1ST2ND_CYCLE:
       5417                         .start
001417 5417 3E02             7          ld      A, 0x02     ; slot-2
001419 5419 215555          10          ld      HL, 0x5555
00141C 541C 1EAA             7          ld      E, 0xaa
00141E 541E CD1400          17          call    B_WRSLT
                                        ;
001421 5421 3E02             7          ld      A, 0x02
001423 5423 21AA2A          10          ld      HL, 0x2aaa
001426 5426 1E55             7          ld      E, 0x55
001428 5428 CD1400          17          call    B_WRSLT
                                        ;
00142B 542B C9              10          ret
                                
                                ;====================================================
                                ; Check FlashROM
                                ;====================================================
       542C                     SST39SF010A_CHECK:
                                    ; @return H=MakerID,L=DeviceID
       542C                         .start
00142C 542C F3               4          di
                                        ;
00142D 542D CD1754          17          call    SST39SF010A_1ST2ND_CYCLE
001430 5430 3E02             7          ld      A, 0x02
001432 5432 215555          10          ld      HL, 0x5555
001435 5435 1E90             7          ld      E, 0x90
001437 5437 CD1400          17          call    B_WRSLT
                                        ;
00143A 543A 3E02             7          ld      A, 0x02
00143C 543C 210040          10          ld      HL, 0x4000
00143F 543F CD0C00          17          call    B_RDSLT
001442 5442 F5              11          push    AF
001443 5443 3E02             7          ld      A, 0x02
001445 5445 210140          10          ld      HL, 0x4001
001448 5448 CD0C00          17          call    B_RDSLT
00144B 544B 6F               4          ld      L, A
00144C 544C F1              10          pop     AF
00144D 544D 67               4          ld      H, A
00144E 544E E5              11          push    HL
                                        ;
00144F 544F CD1754          17          call    SST39SF010A_1ST2ND_CYCLE
001452 5452 3E02             7          ld      A, 0x02
001454 5454 215555          10          ld      HL, 0x5555
001457 5457 1EF0             7          ld      E, 0xF0
001459 5459 CD1400          17          call    B_WRSLT
                                        ;
00145C 545C FB               4          ei
00145D 545D E1              10          pop     HL
00145E 545E C9              10          ret
                                
                                ;====================================================
                                ; Erase FlashROM contents(Chip Earse)
                                ;====================================================
       545F                     SST39SF010A_CHIPERASE:
       545F                         .start
00145F 545F F3               4          di
                                        ;
001460 5460 CD1754          17          call    SST39SF010A_1ST2ND_CYCLE
                                        ;
001463 5463 3E02             7          ld      A, 0x02
001465 5465 215555          10          ld      HL, 0x5555
001468 5468 1E80             7          ld      E, 0x80
00146A 546A CD1400          17          call    B_WRSLT
                                        ;
00146D 546D CD1754          17          call    SST39SF010A_1ST2ND_CYCLE
                                        ;
001470 5470 3E02             7          ld      A, 0x02
001472 5472 215555          10          ld      HL, 0x5555
001475 5475 1E10             7          ld      E, 0x10
001477 5477 CD1400          17          call    B_WRSLT
                                        ;
00147A 547A FB               4          ei
                                
                                    ; 約100ms 待つ!
00147B 547B 3E07             7          ld      A, 0x07     ;16.6ms x 7 = 116.2ms
00147D 547D CD3E55          17          call    SST39SF010A_WAIT_MS
001480 5480 C9              10          ret
                                
                                ;====================================================
                                ; Erase FlashROM contents(0000-FFFF)
                                ;====================================================
                                ; @param reg.H(ssss0000b: ssssb=sector number 0-11)
                                ;   12以降はBIOSの仕組み上不可能
       5481                     SST39SF010A_SECTORERASE:
       5481                         .start
001481 5481 F3               4          di
001482 5482 E5              11          push    HL
                                        ;
001483 5483 CD1754          17          call    SST39SF010A_1ST2ND_CYCLE
                                        ;
001486 5486 3E02             7          ld      A, 0x02
001488 5488 215555          10          ld      HL, 0x5555
00148B 548B 1E80             7          ld      E, 0x80
00148D 548D CD1400          17          call    B_WRSLT
                                        ;
001490 5490 CD1754          17          call    SST39SF010A_1ST2ND_CYCLE
                                        ;
001493 5493 E1              10          pop     HL          ; H(ssss0000b) セクタ番号
001494 5494 2E00             7          ld      L, 0
001496 5496 3E02             7          ld      A, 0x02
001498 5498 1E30             7          ld      E, 0x30
00149A 549A CD1400          17          call    B_WRSLT
                                        ;
00149D 549D FB               4          ei
                                    ; 約25ms 待つ!
00149E 549E 3E03             7          ld      A, 0x03     ;16.6ms x 3 = 49.5ms
0014A0 54A0 CD3E55          17          call    SST39SF010A_WAIT_MS
0014A3 54A3 C9              10          ret
                                
                                
       54A4                     SST39SF010A_SECTORERASE_P3:
       54A4                         .start
0014A4 54A4 F3               4          di
0014A5 54A5 E5              11          push    HL
                                        ;
0014A6 54A6 CD1754          17          call    SST39SF010A_1ST2ND_CYCLE
                                        ;
0014A9 54A9 3E02             7          ld      A, 0x02
0014AB 54AB 215555          10          ld      HL, 0x5555
0014AE 54AE 1E80             7          ld      E, 0x80
0014B0 54B0 CD1400          17          call    B_WRSLT
                                        ;
0014B3 54B3 CD1754          17          call    SST39SF010A_1ST2ND_CYCLE
                                        ;
0014B6 54B6 E1              10          pop     HL          ; H(ssss0000b) セクタ番号
0014B7 54B7 54               4          ld      D, H
                                
                                        ; page3の場合はスタックエリアを別の場所に移動する
0014B8 54B8 210000          10          ld      HL, 0
0014BB 54BB 39              11          add     HL, SP
0014BC 54BC 22CF59          16          ld      (LOCALSTACK.save), HL
0014BF 54BF 31FF59          10          ld      SP, LOCALSTACK.bottom
                                
                                        ; 書込み
0014C2 54C2 62               4          ld      H, D
0014C3 54C3 2E00             7          ld      L, 0
0014C5 54C5 3E30             7          ld      A, 0x30
0014C7 54C7 CD5A53          17          call    WR_SLT2_P3  ; slot2.[HL] <- A
                                
                                        ;スタック領域を本来の位置に戻す
0014CA 54CA 2ACF59          16          ld      HL, (LOCALSTACK.save)
0014CD 54CD F9               6          ld      SP, HL
                                        ;
0014CE 54CE FB               4          ei
                                    ; 約25ms 待つ!
0014CF 54CF 3E03             7          ld      A, 0x03     ;16.6ms x 3 = 49.5ms
0014D1 54D1 CD3E55          17          call    SST39SF010A_WAIT_MS
0014D4 54D4 C9              10          ret
                                
                                
                                ;====================================================
                                ; Write to FlashROM
                                ;====================================================
       54D5                     SST39SF010A_WRITE:
                                    ; @param HL:dest, E:value
       54D5                         .start
0014D5 54D5 F3               4          di
                                        ;
0014D6 54D6 E5              11          push    HL
0014D7 54D7 D5              11          push    DE
0014D8 54D8 CD1754          17          call    SST39SF010A_1ST2ND_CYCLE
0014DB 54DB 3E02             7          ld      A, 0x02
0014DD 54DD 215555          10          ld      HL, 0x5555
0014E0 54E0 1EA0             7          ld      E, 0xA0
0014E2 54E2 CD1400          17          call    B_WRSLT
0014E5 54E5 D1              10          pop     DE
0014E6 54E6 E1              10          pop     HL
                                        ;
0014E7 54E7 D5              11          push    DE
0014E8 54E8 3E02             7          ld      A, 0x02
0014EA 54EA CD1400          17          call    B_WRSLT
0014ED 54ED D1              10          pop     DE
                                        ;
       54EE                         .verify
0014EE 54EE D5              11          push    DE
0014EF 54EF 3E02             7          ld      A, 0x02
0014F1 54F1 CD0C00          17          call    B_RDSLT
0014F4 54F4 D1              10          pop     DE
0014F5 54F5 BB               4          cp      E
0014F6 54F6 20F6            12          jr      nz, .verify
                                        ;
0014F8 54F8 FB               4          ei
       54F9                         .end
0014F9 54F9 C9              10          ret
                                
       54FA                     SST39SF010A_WRITE_P3:
                                    ; @param HL:dest, E:value
       54FA                         .start
0014FA 54FA F3               4          di
0014FB 54FB 223A55          16          ld      (.workdw_hl), HL
0014FE 54FE ED533C55        20          ld      (.workdw_de), DE
001502 5502 CD1754          17          call    SST39SF010A_1ST2ND_CYCLE
001505 5505 3E02             7          ld      A, 0x02
001507 5507 215555          10          ld      HL, 0x5555
00150A 550A 1EA0             7          ld      E, 0xA0
00150C 550C CD1400          17          call    B_WRSLT
                                
       550F                         .write
                                        ; page3の場合はスタックエリアを別の場所に移動する
00150F 550F 210000          10          ld      HL, 0
001512 5512 39              11          add     HL, SP
001513 5513 22CF59          16          ld      (LOCALSTACK.save), HL
001516 5516 31FF59          10          ld      SP, LOCALSTACK.bottom
                                
                                        ;
001519 5519 ED5B3C55        20          ld      DE, (.workdw_de)
00151D 551D 7B               4          ld      A, E
00151E 551E 2A3A55          16          ld      HL, (.workdw_hl)
001521 5521 CD5A53          17          call    WR_SLT2_P3  ; slot2.[HL] <- A
                                
       5524                         .verify
                                        ;
001524 5524 2A3A55          16          ld      HL, (.workdw_hl)
001527 5527 CDB453          17          call    RD_SLT2_P3  ; A <- slot2.[HL]
                                        ;
00152A 552A ED5B3C55        20          ld      DE, (.workdw_de)
00152E 552E BB               4          cp      E
00152F 552F 20F3            12          jr      nz, .verify
                                
                                        ;スタック領域を本来の位置に戻す
001531 5531 2ACF59          16          ld      HL, (LOCALSTACK.save)
001534 5534 F9               6          ld      SP, HL
001535 5535 2A3A55          16          ld      HL, (.workdw_hl)
001538 5538 FB               4          ei
       5539                         .end
001539 5539 C9              10          ret
       553A                         .workdw_hl  
00153A 553A 0000                        dw      0
       553C                         .workdw_de
00153C 553C 0000                        dw      0
                                
                                
                                ;====================================================
                                ; Write to FlashROM
                                ;====================================================
       553E                     SST39SF010A_WAIT_MS:
                                ; @param @reg.A tick(1=16.6ms)
       553E                         .start
00153E 553E 219EFC          10          ld      HL, W_JIFFY
001541 5541 86               7          add     A, (HL)
       5542                         .@1
001542 5542 BE               7          cp      (HL)
001543 5543 20FD            12          jr      nz, .@1
001545 5545 C9              10          ret
[EOF:flashrom.z80:UTF_8]
                                
                                ;================================================================================================
                                ; 作業ワークエリア
                                ;================================================================================================
                                ; 0x4000-0x59EE 6639 Menu-program.
                                ; 0x59CF-0x59FF 48   Stack area
                                ; 0x5A00-0x5DFF 1024 CTXTB.buff
                                ; 0x5E00-0x5EFF 256 work-ram
                                ; 0x5F00-0x7FFF     Picoとの通信を行うためのエリアA
                                ;
0019CF 59CF                     org 0x59CF
       59CF                     LOCALSTACK:
0019CF 59CF                         .save       ds  2
0019D1 59D1                         .top        ds  46
       59FF                         .bottom
                                
001A00 5A00                     org 0x5A00
       5A00                     CTXTB:
001A00 5A00                         .buff       ds  960
001DC0 5DC0                         .work       ds  64
                                
001E00 5E00                     org 0x5E00
       5E00                     WA_FILES:
001E00 5E00                         .tmp_str        ds  15+1    ; 6+1,3+1+3+1+4+2+1
       5E10                         .file_xy
001E10 5E10                         .file_y         ds  1
001E11 5E11                         .file_x         ds  1
001E12 5E12                         .ptr            ds  2
001E14 5E14                         .sel_no         ds  1   ; 画面内のファイル選択の番号 1 ～ 3*18
001E15 5E15                         .total_files    ds  2   ; 総ファイル数 0~999
001E17 5E17                         .disp_top_fno   ds  2   ; 表示先頭ファイル番号 1～
                                
                                ; 選択ファイルのへのアクション
       5E19                     WA_ACTMENU:
001E19 5E19                         .func_ptr   ds  2
                                
                                ; FlashROM書き込みの問い合わせ
       5E1B                     WA_STOREROMQRY:
001E1B 5E1B                         .sel_no     ds  1
001E1C 5E1C                         .block_no   ds  1
001E1D 5E1D                         .read_ptr   ds  2
001E1F 5E1F                         .write_ptr  ds  2
001E21 5E21 0100                    .device     dw  1
                                
                                ; ファイル名称の入力
       5E23                     WA_FNAME:
       5E23                         .name       ds  8+1
       5E2C                         .len        ds  1   ; 文字長
                                
       5E2D                     WA_FWRPROG:
       5E2D                         .block_cnt  ds  1
       5E2E                         .read_ptr   ds  2
       5E30                         .write_ptr  ds  2
                                
       5E32                     WA_VSELECT:
       5E32                         .home_xy    ds  1*2 ; 選択肢の原点
       5E34                         .max_no     ds  1   ; アイテム数-1
       5E35                         .sel_no     ds  1   ; 0～
                                
                                
                                ;CT-ARK(Pico)との通信を行うためのエリアA
       5F00                     org 0x5F00
       5F00                     MSXPICO_IF:
                                    ; ここにこの文字列を書き込むとPico側がコマンドを受け付けるモードになる
                                    ; それまではタダのROMとして動作する
       5F00                         .magic_word         ds  12  ; "OPEN THE ARK"
                                
                                    ; Infomation
                                    ; idが書き込まれると、Pico側のVer文字列が格納される
       5F0C                         .pico_side_version  ds  5+1 ; "xx.xx" + \0
                                
                                    ; idが書き込まれると、Picoの動作周波数[Mhz]が文字列で格納される ex)"125"
       5F12                         .pico_clock_mhz     ds  5+1 ; "(xxx)" + \0
                                
                                    ; 起動設定されているROMファイル名がPico側から格納される
       5F18                         .boot_rom_name      ds  13  ; "xxxxxxxx.xxx\0" (8+1+3+1)
                                
                                    ;Command
                                    ; .cmd にコマンドを書く前に 0 にしておくこと。.cmdにコマンドを書き込んだ後、
                                    ; ここに.cmdに書き込んだ値と同じ値が格納される
       5F25                         .cmd_res            ds  1   ; 
                                    ;
       5F26                         .cmds equ $
                                
                                ;----------
       5F26                     org MSXPICO_IF.cmds
       5F26                     MSXPICO_IF_BASE:
       5F26                         .code                   ds  1       ; IFCMD.*
       5F27                         .cmd_value              ds  1       ; 
       5F28                         .end                    equ $
                                
       5F26                     org MSXPICO_IF.cmds
       5F26                     MSXPICO_IF_UPDATE_FILELIST:
       5F26                         .code                   ds  1       ; IFCMD.REQ_FILELIST
       5F27                         .action                 ds  1       ; 0固定
                                    ;以下はpico->msx
       5F28                         .status                 ds  1       ; 0:no sd card, !0:files
       5F29                         .total_num_files        ds  2       ; 総ファイル数
       5F2B                         .end                    equ $
                                
       5F26                     org MSXPICO_IF.cmds
       5F26                     MSXPICO_IF_REQ_FILELIST:
       5F26                         .code                   ds  1       ; IFCMD.REQ_FILELIST
       5F27                         .action                 ds  1       ; 不使用
       5F28                         .req_topno              ds  2       ; 先頭ファイル番号
                                    ;以下はpico->msx
       5F2A                         .status                 ds  1       ; 0:no sd card, !0:files
       5F2B                         .padding1               ds  1       ; 不使用
       5F2C                         .padding2               ds  1       ; 不使用
       5F2D                         .files                  ds  SIZE_FILERECORD*3*18    ; MSXPICOIF_FILERECORD[3列*18行]
       62F9                         .end                    equ $
                                
       5F26                     org MSXPICO_IF.cmds
       5F26                     MSXPICO_IF_STR_SET_ROM:
       5F26                         .code                   ds  1       ; IFCMD.SET_ROM
       5F27                         .file_no                ds  1       ; 選択ファイル番号 0:選択無し 1～:ROMファイル番号
       5F28                         .boot_rom_type          ds  1       ; ROM TYPE
       5F29                         .end                    equ $
                                
       5F26                     org MSXPICO_IF.cmds
       5F26                     MSXPICO_IF_STR_DEL_ROMFILE:
       5F26                         .code                   ds  1       ; IFCMD.DEL_ROMFILE
       5F27                         .file_no                ds  1       ; 削除したいROMファイル番号 1～
       5F28                         .end                    equ $
                                
       5F26                     org MSXPICO_IF.cmds
       5F26                     MSXPICO_IF_STR_WR_FILE:
       2000                         .BLOCK_SIZE             equ 0x2000
       5F26                         .code                   ds  1           ; IFCMD.WR_FILE
       5F27                         .block_no               ds  1           ; 0x2000サイズ単位のブロック番号 0～
       5F28                         .cmd_fwr_fspec          ds  8+1         ; 保存ファイル名（拡張子無し）
       5F31                         .block_data             ds  .BLOCK_SIZE ; ブロックデータ
       7F31                         .end                    equ $
                                
       5F26                     org MSXPICO_IF.cmds
       5F26                     MSXPICO_IF_STR_BAS2ROM:
       5F26                         .code                   ds  1       ; IFCMD.BAS2ROM
       5F27                         .file_no                ds  1       ; ROMファイルに変換したいBASファイルの番号 1～
       5F28                         .cmd_fwr_fspec          ds  8+1     ; 保存ファイル名（拡張子無し）
       5F31                         .end                    equ $
                                
       5F26                     org MSXPICO_IF.cmds
       5F26                     MSXPICO_IF_STR_STORE_ROM:
       2000                         .BLOCK_SIZE             equ 0x2000
       5F26                         .code                   ds  1           ; IFCMD.STORE_ROM
       5F27                         .file_no                ds  1           ; ROMへ書き込みたいROMファイルの番号 1～
       5F28                         .block_no               ds  1           ; 0x2000サイズ単位のブロック番号 0～
                                    ;以下はpico->msx
       5F29                         .err_no                 ds  1           ; 0:ファイル読み込みOK、1:何らかの理由で読み込みできず
       5F2A                         .str_num_total_block    ds  1           ; ファイル全体のブロック数
       5F2B                         .str_block              ds  1           ; 0:要求されたブロックは無し、1:有り
       5F2C                         .str_block_data         ds  .BLOCK_SIZE ; ブロックデータ
       7F2C                         .end                    equ $
                                
       5F26                     org MSXPICO_IF.cmds
       5F26                     MSXPICO_IF_STR_SET_FREQ:
       5F26                         .code                   ds  1       ; IFCMD.SET_FREQ
       5F27                         .freq_mhz               ds  1       ; 周波数MHz 125～300MHz
       5F28                         .end                    equ $
                                
       5F26                     org MSXPICO_IF.cmds
       5F26                     MSXPICO_IF_STR_CLEAR_EPAPER:
       5F26                         .code                   ds  1       ; IFCMD.CLEAR_E_PAPER
       5F27                         .cmd_value              ds  1       ; no use
       5F28                         .end                    equ $
                                
                                
[EOF:ct-ark2.z80:UTF_8]
