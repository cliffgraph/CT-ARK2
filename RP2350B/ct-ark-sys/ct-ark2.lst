00138A 538A 78               4          ld      A, B
00138B 538B E63F             7          and     0x3F                ; ページ3のビット(7-6)をクリアし、
00138D 538D F680             7          or      0x80                ; ページ3にスロット2を指定する (10_00_00_00B)
00138F 538F D3A8            11          out     (0xA8), A           ; 基本スロット切り替え実行
                                
