       4403                     GET_PTR_FILERECORD:
                                ; @param A カーソル位置
                                ; @reurn HL FILERECORDへのアドレス
                                ; @note use A
       4403                         .start
000403 4403 D5              11          push    DE
000404 4404 C5              11          push    BC
000405 4405 3D               4          dec     A
