                                ;=========================================
                                ; ROM読み取りとファイルへの書き込み処理
                                ;=========================================
       4D6B                     FUNC_FWRITE_PROGRESS:
       4D6B                         .start
                                    ; 入力されたファイル名の取り込み
000D6B 4D6B 21235E          10          ld      HL, WA_FNAME.name
000D6E 4D6E 11285F          10          ld      DE, MSXPICO_IF_STR_WR_FILE.cmd_fwr_fspec
000D71 4D71 3A2C5E          13          ld      A, (WA_FNAME.len)
000D74 4D74 47               4          ld      B, A
       4D75                         .@1
000D75 4D75 7E               7          ld      A, (HL)
000D76 4D76 FE20             7          cp      ' '
000D78 4D78 2809            12          jr      z, .@2
000D7A 4D7A FE00             7          cp      0x00
000D7C 4D7C 2805            12          jr      z, .@2
000D7E 4D7E 12               7          ld      (DE), A
000D7F 4D7F 23               6          inc     HL
000D80 4D80 13               6          inc     DE
000D81 4D81 10F2            13          djnz    .@1
       4D83                         .@2
000D83 4D83 AF               4          xor     A
000D84 4D84 12               7          ld      (DE), A ; "\0"
                                    ;
000D85 4D85 21014E          10          ld      HL, .scr_fwrite_progress
000D88 4D88 CD1541          17          call    CTXTF.go_scr
000D8B 4D8B CD5601          17          call    B_KILBUF
000D8E 4D8E AF               4          xor     A
000D8F 4D8F 322D5E          13          ld      (WA_FWRPROG.block_cnt), A       ; start_addrs[0]を表している
       4D92                         .page_loop
000D92 4D92 CB27             8          sla     A               ; A *= 2
000D94 4D94 4F               4          ld      C, A
000D95 4D95 0600             7          ld      B, 0
000D97 4D97 21F94D          10          ld      HL, .start_addrs
000D9A 4D9A 09              11          add     HL, BC
000D9B 4D9B 4E               7          ld      C, (HL)
000D9C 4D9C 23               6          inc     HL
000D9D 4D9D 46               7          ld      B, (HL)
000D9E 4D9E ED432E5E        20          ld      (WA_FWRPROG.read_ptr), BC
                                    ; ; 読み取りアドレスを表示
                                    ;   ld      DE, 0x1a13          ; locate(26,19)
                                    ;   call    CTXTF.buff_print4hex
                                    ;   call    CTXTF.buff_present
                                
                                    ;読み取りを始める
000DA2 4DA2 21315F          10          ld      HL, MSXPICO_IF_STR_WR_FILE.block_data
000DA5 4DA5 22305E          16          ld      (WA_FWRPROG.write_ptr), HL
000DA8 4DA8 010020          10          ld      BC, MSXPICO_IF_STR_WR_FILE.BLOCK_SIZE
       4DAB                         .loop_block
000DAB 4DAB C5              11          push    BC
000DAC 4DAC CD2E51          17          call    GET_CHAR
000DAF 4DAF FE1B             7          cp      KEY_ESC         ; ESCキーで中断する
000DB1 4DB1 2844            12          jr      z, .force_prog_end
                                        ;
                                        ; 読み取りアドレスを表示
000DB3 4DB3 ED4B2E5E        20          ld      BC, (WA_FWRPROG.read_ptr)
000DB7 4DB7 AF               4          xor     A
000DB8 4DB8 B9               4          cp      C
000DB9 4DB9 2009            12          jr      nz, .@1
000DBB 4DBB 11131A          10          ld      DE, 0x1a13          ; locate(26,19)
000DBE 4DBE CDC440          17          call    CTXTF.buff_print4hex
000DC1 4DC1 CDCD40          17          call    CTXTF.buff_present
       4DC4                         .@1
000DC4 4DC4 2A2E5E          16          ld      HL, (WA_FWRPROG.read_ptr)
000DC7 4DC7 3E02             7          ld      A, 0x02             ; Primary slot no.2
000DC9 4DC9 CD0C00          17          call    B_RDSLT             ; read value -> A, use AF,BC,DE
000DCC 4DCC 23               6          inc     HL
000DCD 4DCD 222E5E          16          ld      (WA_FWRPROG.read_ptr), HL
000DD0 4DD0 2A305E          16          ld      HL, (WA_FWRPROG.write_ptr)
000DD3 4DD3 77               7          ld      (HL), A
000DD4 4DD4 23               6          inc     HL
000DD5 4DD5 22305E          16          ld      (WA_FWRPROG.write_ptr), HL
                                
000DD8 4DD8 C1              10          pop     BC
000DD9 4DD9 0B               6          dec     BC
000DDA 4DDA 78               4          ld      A, B
000DDB 4DDB B1               4          or      C           ;; BCが 0 か否か？
000DDC 4DDC 20CD            12          jr      nz, .loop_block
                                        ; 書き込み依頼
000DDE 4DDE 3A2D5E          13          ld      A, (WA_FWRPROG.block_cnt)
000DE1 4DE1 47               4          ld      B, A
000DE2 4DE2 3E06             7          ld      A, IFCMD.WR_FILE
000DE4 4DE4 CD8044          17          call    FUNC_CMD_TO_CTARK
                                        ;
000DE7 4DE7 3A2D5E          13          ld      A, (WA_FWRPROG.block_cnt)
000DEA 4DEA 3C               4          inc     A
000DEB 4DEB 322D5E          13          ld      (WA_FWRPROG.block_cnt), A
000DEE 4DEE FE04             7          cp      4
000DF0 4DF0 C2924D          10          jp      nz, .page_loop
       4DF3                         .prog_end
                                        ; 終了メッセージ
000DF3 4DF3 CD134C          17          call    FUNC_DONE_MESSAGE
000DF6 4DF6 C9              10          ret
       4DF7                         .force_prog_end
000DF7 4DF7 C1              10          pop     BC
000DF8 4DF8 C9              10          ret
                                
       4DF9                         .start_addrs
000DF9 4DF9 00400060008000A0            dw      0x4000, 0x6000, 0x8000, 0xA000
       4E01                         .scr_fwrite_progress
                                        ; "+---------------------+ "
