001394 5394 E680             7          and     0x80                    ; 拡張スロットか？
001396 5396 280A            12          jr      z, .write_data          ; 拡張されていなければ、そのまま書き込みへ
                                
001398 5398 3A1654          13          ld      A, (WA_SLT2_P3.local_W_SLTTBL2) ; スロット2の現在の拡張スロット状態を取得
00139B 539B E63F             7          and     0x3F                    ; ページ3のサブスロット指定(ビット7-6)をクリア
00139D 539D F600             7          or      0x00                    ; ここでページ3のサブスロットをしていするが、今は、0 とする
                                
00139F 539F 32FFFF          13          ld      (0xFFFF), A         ; 拡張スロットレジスタ(0xFFFF)に書き込み
                                
