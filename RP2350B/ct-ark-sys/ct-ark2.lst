000408 4408 CD1353          17          call    MULTI8X8R16
00040B 440B 112D5F          10          ld      DE, MSXPICO_IF_REQ_FILELIST.files
00040E 440E 19              11          add     HL, DE
00040F 440F C1              10          pop     BC
000410 4410 D1              10          pop     DE
       4411                         .end
000411 4411 C9              10          ret
                                
                                ;=========================================
