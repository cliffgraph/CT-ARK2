                                ; ==========================================================
                                ; 選択ファイルのファイル名（除く拡張子）を指定域にコピーする
                                ; ==========================================================
                                ; @param A カーソル位置 1～
                                ; @param HL コピー先
                                ; @return C 文字数
                                ; @usereg AF,BC,DE,HL,IX
       4F92                     COPY_FILESPEC:
000F92 4F92 B7               4          or      A
000F93 4F93 C8              11          ret     z
                                    ;
000F94 4F94 E5              11          push    HL  ; IX <- HL
000F95 4F95 DDE1            14          pop     IX
000F97 4F97 CD0344          17          call    GET_PTR_FILERECORD
000F9A 4F9A 23               6          inc     HL
000F9B 4F9B 23               6          inc     HL
000F9C 4F9C 23               6          inc     HL
000F9D 4F9D 0E00             7          ld      C, 0
       4F9F                         .copy_loop
000F9F 4F9F 7E               7          ld      A, (HL)
000FA0 4FA0 23               6          inc     HL
000FA1 4FA1 B7               4          or      A
000FA2 4FA2 2810            12          jr      z, .copy_end
000FA4 4FA4 FE2E             7          cp      '.'
000FA6 4FA6 280C            12          jr      z, .copy_end
000FA8 4FA8 FE20             7          cp      ' '
000FAA 4FAA 2808            12          jr      z, .copy_end
000FAC 4FAC DD7700          19          ld      (IX+0), A
000FAF 4FAF DD23            10          inc     IX
000FB1 4FB1 0C               4          inc     C
000FB2 4FB2 18EB            12          jr      .copy_loop
       4FB4                         .copy_end
000FB4 4FB4 C9              10          ret
                                
                                ; =====================================
                                ; SCREEN 0, WIDTH40 に設定する
                                ; =====================================
       4FB5                     SCREEN0_40x24:
       006C                     .INITXT     equ 0x006C  ;; BIOS: 画面を TEXT1 モード (40*24) に初期化
       F3AE                     .LINL40     equ 0xF3AE  ;; B_INITXT: 1 行の幅
       F3B3                     .TATNAM     equ 0xF3B3  ;; B_INITXT: パターンネーム・テーブル
       F3B7                     .TXTCGP     equ 0xF3B7  ;; B_INITXT: パターンジェネレータ・テーブル
       4FB5                         .start
000FB5 4FB5 3E28             7          ld      A, 40
000FB7 4FB7 32AEF3          13          ld      (.LINL40), A
000FBA 4FBA 210000          10          ld      HL, 0x0000
000FBD 4FBD 22B3F3          16          ld      (.TATNAM), HL
000FC0 4FC0 210008          10          ld      HL, 0x0800
000FC3 4FC3 22B7F3          16          ld      (.TXTCGP), HL
000FC6 4FC6 CD6C00          17          call    .INITXT
000FC9 4FC9 C9              10          ret
                                
                                ; =====================================
                                ; lns構造の文字列を表示する
                                ; =====================================
                                ; HL = pointer of window structure
                                ; 使用レジスタ AL, B, HL, IX
       4FCA                     PRINT_LNS:
       4FCA                         .start
000FCA 4FCA E5              11          push    HL
000FCB 4FCB DDE1            14          pop     IX
000FCD 4FCD DD4600          19          ld      B, (IX+0)   ;; lines
000FD0 4FD0 DD23            10          inc     IX
000FD2 4FD2 DD6E00          19          ld      L, (IX+0)   ;; locate
000FD5 4FD5 DD23            10          inc     IX
000FD7 4FD7 DD6600          19          ld      H, (IX+0)
000FDA 4FDA DD23            10          inc     IX
       4FDC                         .step1
000FDC 4FDC CDC600          17          call    B_POSIT
000FDF 4FDF 2C               4          inc     L
000FE0 4FE0 E5              11          push    HL
                                        
000FE1 4FE1 DDE5            15          push    IX
000FE3 4FE3 E1              10          pop     HL
000FE4 4FE4 CDEE4F          17          call    PRINT_STR
000FE7 4FE7 E5              11          push    HL
