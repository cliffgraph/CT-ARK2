000416 4416 CD0344          17          call    GET_PTR_FILERECORD
                                        ; no を得る->A, noは16bitsだけど現状下位8bitしか使用していません
000419 4419 7E               7          ld      A, (HL)
00041A 441A E1              10          pop     HL
       441B                         .end
00041B 441B C9              10          ret
                                
