0004BC 44BC CD5452          17          call    VSELECT
       44BF                         .call_subr
0004BF 44BF B7               4          or      A
0004C0 44C0 C8              11          ret     z           ; cancel
0004C1 44C1 47               4          ld      B, A
0004C2 44C2 2A195E          16          ld      HL, (WA_ACTMENU.func_ptr)
0004C5 44C5 3D               4          dec     A
0004C6 44C6 07               4          rlca
0004C7 44C7 5F               4          ld      E, A
0004C8 44C8 1600             7          ld      D, 0
0004CA 44CA 19              11          add     HL, DE
0004CB 44CB 5E               7          ld      E, (HL)
0004CC 44CC 23               6          inc     HL
0004CD 44CD 56               7          ld      D, (HL)
0004CE 44CE EB               4          ex      DE, HL
0004CF 44CF 78               4          ld      A, B        ; A = 選択番号 1～
0004D0 44D0 E9               4          jp      (HL)        ; jp 先でretしている
                                
