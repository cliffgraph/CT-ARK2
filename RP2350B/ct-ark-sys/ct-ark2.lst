                                ;================================================================================================
                                ; ツール類（先頭位置を特定できないので、プログラムの最後でインクルードしておく）
                                ;================================================================================================
                                include "tools.z80"
                                ;・掛け算
                                ; from http://hp.vector.co.jp/authors/VA054130/%EF%BC%BA%EF%BC%98%EF%BC%90%E3%81%AE%E4%B9%97%E9%99%A4%E7%AE%97.txt
                                ; ８ビット×８ビット＝８ビット以内
                                ; 8bit By 8bit = 8bit multiplication
                                ; B=multiplicand, C=multiplier -> A=result
       5305                     MULTI8:
       5305                         .start
001305 5305 AF               4          xor A
       5306                         .@1
001306 5306 0C               4          inc C
001307 5307 0D               4          dec C
001308 5308 C8              11          ret Z
001309 5309 CB39             8          srl C
00130B 530B 3001            12          jr  NC, .noadd
00130D 530D 80               4          add A,B
       530E                         .noadd
00130E 530E CB20             8          sla B
001310 5310 18F4            12          jr  .@1
001312 5312 C9              10          ret
                                
                                ;８ビット×８ビット＝１６ビット　その１
                                ; 8bit By 8bit = 16bit multiplication
                                ; A=multiplicand, E=multiplier -> HL=result
       5313                     MULTI8X8R16:
       5313                         .start
001313 5313 1600             7          ld  D, 0
001315 5315 210000          10          ld  HL, 0
001318 5318 0608             7          ld  B, 8    ; counter
       531A                         .@1
00131A 531A 0F               4          rrca
00131B 531B 3001            12          jr  nc, .noadd
00131D 531D 19              11          add HL,DE
       531E                         .noadd
00131E 531E CB23             8          sla E
001320 5320 CB12             8          rl  D
001322 5322 10F6            13          djnz .@1
001324 5324 C9              10          ret
                                
                                ;・割り算
                                ;８ビット÷８ビット　結果と余り
                                ; 8bit / 8bit division
                                ; A=dividend, B=divisor -> C=result, A=remainder
       5325                     DIV8R:
       5325                         .@1
001325 5325 90               4          sub B
001326 5326 3803            12          jr  c, .remain
001328 5328 0C               4          inc C
001329 5329 18FA            12          jr  .@1
       532B                         .remain
00132B 532B 80               4          add A, B
00132C 532C C9              10          ret
                                
                                
                                
                                ; refer to MSX-Datapack "WHEREAMI.MAC"
                                ; @param reg.A = target PageNo(only 1 or 2)
                                ; @return reg.A = SlotNo infomation of PageNo
                                ;
                                ; Aレジスタにページ番号を入れる（1 or 2）と、そのページに現れているスロットの番号を返す
                                ;このスロット番号は、RDSLT と同じ形式
       0138                     B_RSLREG    equ 0x0138      ; 0-3ページすべての基本スロット番号を返す
       FCC1                     W_EXPTBL    equ 0xfcc1      ; 各スロットの拡張の有無を示すフラグテーブルの先頭アドレス
       FCC5                     W_SLTTBL    equ 0xFCC5      ; 拡張スロットの現在の選択状態を保持するミラー (4バイト)
                                
       532D                     WHEREPAGE:
       532D                         .start
00132D 532D 5F               4          ld      E, A
00132E 532E 47               4          ld      B, A
00132F 532F CD3801          17          call    B_RSLREG
       5332                         .@1
001332 5332 0F               4          rrca                    ; A <= {A[0], A[7:1]}, cf <= A[0]
001333 5333 0F               4          rrca
001334 5334 10FC            13          djnz    .@1
001336 5336 E603             7          and     0x03
001338 5338 4F               4          ld      C, A            ; C には、reg.A で指定していたページ番号の基本スロット番号(0-3)が入る
                                    ;
001339 5339 0600             7          ld      B, 0
00133B 533B 21C1FC          10          ld      HL, W_EXPTBL
00133E 533E 09              11          add     HL, BC
00133F 533F 7E               7          ld      A, (HL)         ; 
001340 5340 E680             7          and     0x80
001342 5342 B1               4          or      C
001343 5343 4F               4          ld      C, A            ; C <= {拡張有無, 3'b000, 基本スロット番号(0-3)}
                                        ;
001344 5344 23               6          inc     HL
001345 5345 23               6          inc     HL
001346 5346 23               6          inc     HL
001347 5347 23               6          inc     HL              ; HLには、対象スロットの、拡張スロット選択レジスタ値の保存エリアへのアドレス
001348 5348 7B               4          ld      A, E            ; A <= reg.A
001349 5349 3D               4          dec     A
00134A 534A 7E               7          ld      A, (HL)         ; reg.A=page1だったのなら、保存エリアの値をそのまま使用する
00134B 534B 2802            12          jr      z, .finish      ; reg.A=page2だったのなら、A <<= 2;
00134D 534D 07               4          rlca
00134E 534E 07               4          rlca
       534F                         .finish
00134F 534F E60C             7          and     0x0c
001351 5351 B1               4          or      C               ; A = {拡張有無、3'b000, 拡張スロット番号(0-3), 基本スロット番号(0-3)}
001352 5352 C9              10          ret
                                
                                ; HL = HL - DE
       5353                     SUB_HL_DE:
       5353                         .start
001353 5353 7D               4          ld      A,L        ; 下位バイト
001354 5354 93               4          sub     E          ; A = L - E
001355 5355 6F               4          ld      L,A
001356 5356 7C               4          ld      A,H        ; 上位バイト
001357 5357 9A               4          sbc     A,D        ; A = H - D - キャリー
001358 5358 67               4          ld      H,A
001359 5359 C9              10          ret
                                
                                
                                
                                ; Generated by Gemini.
                                ; =====================================================================
                                ; サブルーチン: WR_SLT2_P3
                                ; 引数: 
                                ;   HL = 書き込み先アドレス (0xC000-0xFFFF)
                                ;   A  = 書き込みデータ
                                ; 前提条件:
                                ;   - このルーチンおよびスタックはページ3以外（ページ0〜2）にあること
                                ;   - 割り込みは必要に応じて呼び出し側で禁止(DI)しておくことを推奨
                                ; =====================================================================
       535A                     WR_SLT2_P3:
       535A                         .start
00135A 535A C5              11          push    BC
00135B 535B D5              11          push    DE
00135C 535C F5              11          push    AF
                                
00135D 535D 3AC3FC          13          ld      A, (W_EXPTBL+2) 
001360 5360 321554          13          ld      (WA_SLT2_P3.local_W_EXPTBL2), A
001363 5363 3AC7FC          13          ld      A, (W_SLTTBL+2) 
001366 5366 321654          13          ld      (WA_SLT2_P3.local_W_SLTTBL2), A
                                
                                        ; -----------------------------------------------------------------
                                        ; 1. 現在のページ3のスロット状態（基本・拡張）を保存する
                                        ; -----------------------------------------------------------------
001369 5369 DBA8            11          in      A, (0xA8)       ; 基本スロットレジスタ読み込み
00136B 536B 47               4          ld      B, A
                                
                                        ; 現在ページ3に選択されている基本スロット番号を割り出す (ビット7-6)
00136C 536C 07               4          rlca
00136D 536D 07               4          rlca
00136E 536E E603             7          and     0x03            ; A = 現在のページ3の基本スロット番号 (0〜3)
001370 5370 5F               4          ld      E, A
001371 5371 1600             7          ld      D, 0
001373 5373 FD21C1FC        14          ld      IY, W_EXPTBL
001377 5377 FD19            15          add     IY, DE          ; IY = W_EXPTBL + 基本スロット番号
001379 5379 FD4E00          19          ld      C, (IY+0)       ; C = 元の基本スロットが拡張されているかのフラグ (MSBが1なら拡張)
                                
00137C 537C 79               4          ld      A, C
00137D 537D 07               4          rlca                        ; 拡張フラグをCyフラグへ
00137E 537E 300A            12          jr      nc, .skip_save_sub  ; スロットが拡張されていなければ、拡張ミラーの保存はスキップ
                                        ; 現在のページ3が拡張スロットだった場合、現在の拡張スロットレジスタの内容を保存
001380 5380 FD21C5FC        14          ld      IY, W_SLTTBL
001384 5384 FD19            15          add     IY, DE              ; IY = W_SLTTBL + 基本スロット番号
001386 5386 FD7E00          19          ld      A, (IY+0)           ; 
001389 5389 57               4          ld      D, A                ; Dレジスタに切り替え前の拡張スロット状態を保存
                                
       538A                         .skip_save_sub
                                        ; この時点で、切替前の、
                                        ; Bレジスタ = 基本スロットレジスタの値
                                        ; Cレジスタ = 基本スロットの拡張フラグ
                                        ; Dレジスタ = 拡張スロットミラーの値 (拡張の場合のみ有効)
                                
                                        ; -----------------------------------------------------------------
                                        ; 2. ページ3を「スロット2」に切り替える
                                        ; -----------------------------------------------------------------
