0010F5 50F5 CB08             8          rrc     B
0010F7 50F7 CB08             8          rrc     B
0010F9 50F9 CB08             8          rrc     B
0010FB 50FB CB08             8          rrc     B
0010FD 50FD 78               4          ld      A, B
0010FE 50FE CD0F51          17          call    TOSTR_ONECONV
001101 5101 CB08             8          rrc     B
001103 5103 CB08             8          rrc     B
001105 5105 CB08             8          rrc     B
001107 5107 CB08             8          rrc     B
001109 5109 78               4          ld      A, B
00110A 510A CD0F51          17          call    TOSTR_ONECONV
00110D 510D 72               7          ld      (HL), D     ;; '\0'
00110E 510E C9              10          ret
                                
       510F                     TOSTR_ONECONV:
                                    ; A=4bit-val
                                    ; D=0
       510F                         .start
00110F 510F E60F             7          and     0x0f
001111 5111 5F               4          ld      E, A
001112 5112 DD211E51        14          ld      IX, .chars
001116 5116 DD19            15          add     IX, DE
001118 5118 DD7E00          19          ld      A, (IX+0)
00111B 511B 77               7          ld      (HL), A
00111C 511C 23               6          inc     HL
00111D 511D C9              10          ret
       511E                         .chars
00111E 511E 3031323334353637            db      "0123456789ABCDEF"
            3839414243444546    
                                
                                ; =====================================
                                ;キーボードバッファからキーコードを取得する
                                ; =====================================
                                ; B_CHGET(009FH)を使用しないので、入力待ちを行いません
                                ; バッファにキーコードがない場合、z=ONで返る。
                                ; キーコードが取得できた場合、A=キーコード、z=offとなります
                                ; *変更レジスタ AF
       512E                     GET_CHAR:
       009C                             B_CHSNS     equ 0x009C      ;; use AF
       0020                             B_DCOMPR    equ 0x0020      ;; use AF
       F3FA                             W_GETPNT    equ 0xF3FA
       FBF0                             W_KEYBUF    equ 0xFBF0
       FC18                             D_BUFEND    equ 0xFC18
       512E                         .start
00112E 512E CD9C00          17          call    B_CHSNS         ;;空なら即終了
001131 5131 C8              11          ret     z
                                        ;
001132 5132 E5              11          push    HL
001133 5133 2AFAF3          16          ld      HL, (W_GETPNT)
001136 5136 7E               7          ld      A, (HL)
001137 5137 F5              11          push    AF
001138 5138 23               6          inc     HL
001139 5139 D5              11          push    DE
00113A 513A 1118FC          10          ld      DE, D_BUFEND
00113D 513D CD2000          17          call    B_DCOMPR
001140 5140 D1              10          pop     DE
001141 5141 2003            12          jr      nz, .step1
001143 5143 21F0FB          10          ld      HL, W_KEYBUF    ;;ポインタを先頭に戻す
       5146                         .step1
001146 5146 22FAF3          16          ld      (W_GETPNT), HL
001149 5149 F1              10          pop     AF
00114A 514A E1              10          pop     HL
00114B 514B C9              10          ret
                                
                                
