		dw	.item_ok

;=========================================
; SIMPLE_ROM_CARTRIDGE の消去用メニュー
;=========================================
FUNC_ROM_ERASER:
	.init
		call	SST39SF010A_CHECK
		ld		(WA_STOREROMQRY.device), HL
		call	FUNC_PRT_CHIPMODEL
		or		A
		jr		nz, .found_simplerom
		; not_found_simplerom
		call	B_BEEP
		call	FUNC_NOTFOUND_SIMPLEROM
		ret
	.found_simplerom
		ld		HL, .scr_rom_eraser
		call	CTXT_MENU
		jp		z, .item_cancel
		ret
	.scr_rom_eraser
		; "+ROM ERASER ----------------+"
		; "|Target slot is SLOT2 only  |"
		; "+---------------------------+"
		; "|  ALL ERASE                |"
		; "|  64K ERASE                |"
		; "|  CANCEL                   |"
		; "+--------------[ESC]:CANCEL-+"
		db	CTXT.box,		5,1, 5,30
		db	CTXT.prints,	5,2,
		db		"ROM ERASER", 0
		db		"Target slot is SLOT2 only", 0, CTXT.EOT
		db	CTXT.boxseph,	7,1, 30
		db	CTXT.prints,	8,4,
		db		"ALL  (CHIP ERASE)", 0
		db		"64K  (0000-FFFF)", 0
		db		"CANCEL", 0, CTXT.EOT
		db	CTXT.prints,	11,19, "[ESC]:CANCEL", 0, CTXT.EOT
		db	CTXT.chars,		12,2, ' ', 32
		db	CTXT.present
		db	CTXT.endc
		db	3			; 選択項目数
		db	3, 8		; カーソル原点座標 X,Y
		db	1			; デフォルト選択されている綱目番号
		dw	.item_erase_all
		dw	.item_erase_64k
		dw	.item_cancel
	.item_erase_all
		call	FUNC_CHIPERASE_QUERY	; チップ全体を消去する
		ret
	.item_erase_64k
		call	FUNC_64KERASE_QUERY		; Z80から見える64KBの空間を消去する
		ret
	.item_cancel
		ret

;=========================================
; ROM読み取りとファイルへの書き込み処理
;=========================================
FUNC_FWRITE_PROGRESS:
	.start
	; 入力されたファイル名の取り込み
		ld		HL, WA_FNAME.name
		ld		DE, MSXPICO_IF_STR_WR_FILE.cmd_fwr_fspec
		ld		A, (WA_FNAME.len)
		ld		B, A
	.@1
		ld		A, (HL)
		cp		' '
		jr		z, .@2
		cp		0x00
		jr		z, .@2
		ld		(DE), A
		inc		HL
		inc		DE
		djnz	.@1
	.@2
		xor		A
		ld		(DE), A	; "\0"
	;
		ld		HL, .scr_fwrite_progress
		call	CTXTF.go_scr
		call	B_KILBUF
		xor		A
		ld		(WA_FWRPROG.block_cnt), A		; start_addrs[0]を表している
	.page_loop
		sla		A				; A *= 2
		ld		C, A
		ld		B, 0
		ld		HL, .start_addrs
		add		HL, BC
		ld		C, (HL)
		inc		HL
		ld		B, (HL)
		ld		(WA_FWRPROG.read_ptr), BC
	; ; 読み取りアドレスを表示
	; 	ld		DE, 0x1a13			; locate(26,19)
	; 	call	CTXTF.buff_print4hex
	; 	call	CTXTF.buff_present

	;読み取りを始める
		ld		HL, MSXPICO_IF_STR_WR_FILE.block_data
		ld		(WA_FWRPROG.write_ptr), HL
		ld		BC, MSXPICO_IF_STR_WR_FILE.BLOCK_SIZE
	.loop_block
		push	BC
		call	GET_CHAR
		cp		KEY_ESC			; ESCキーで中断する
		jr		z, .force_prog_end
		;
		; 読み取りアドレスを表示
		ld		BC, (WA_FWRPROG.read_ptr)
		xor		A
		cp		C
		jr		nz, .@1
		ld		DE, 0x1a13			; locate(26,19)
		call	CTXTF.buff_print4hex
		call	CTXTF.buff_present
	.@1
		ld		HL, (WA_FWRPROG.read_ptr)
		ld		A, 0x02				; Primary slot no.2
		call	B_RDSLT				; read value -> A, use AF,BC,DE
		inc		HL
		ld		(WA_FWRPROG.read_ptr), HL
		ld		HL, (WA_FWRPROG.write_ptr)
		ld		(HL), A
		inc		HL
		ld		(WA_FWRPROG.write_ptr), HL

		pop		BC
		dec		BC
		ld		A, B
		or		C			;; BCが 0 か否か？
		jr		nz, .loop_block
		; 書き込み依頼
		ld		A, (WA_FWRPROG.block_cnt)
		ld		B, A
		ld		A, IFCMD.WR_FILE
		call	FUNC_CMD_TO_CTARK
		;
		ld		A, (WA_FWRPROG.block_cnt)
		inc		A
		ld		(WA_FWRPROG.block_cnt), A
		cp		4
		jp		nz, .page_loop
	.prog_end
		; 終了メッセージ
		call	FUNC_DONE_MESSAGE
		ret
	.force_prog_end
		pop		BC
		ret

	.start_addrs
		dw		0x4000, 0x6000, 0x8000, 0xA000
	.scr_fwrite_progress
		; "+---------------------+ "
		; "| READ ADDRESS : xxxx | "
		; "+--------[ESC]:CANCEL-+ "
		; "                        "
		db	CTXT.box,		18,9, 1,21
		db	CTXT.prints,	19,11, "READ ADDRESS : xxxx", 0, CTXT.EOT
		db	CTXT.prints,	20,17, "[ESC]:CANCEL", 0, CTXT.EOT
		db	CTXT.chars,		21,10, ' ', 23
		db	CTXT.present
		db	CTXT.endc

;=========================================
; CHANGE PICO CPU CLOCK
;=========================================
FUNC_CPUCLOCK:
	.init
		ld		HL, .scr_cpuclock
		call	CTXT_MENU
		ret
	.scr_cpuclock
		; "+-CHANGE PICO CPU CLOCK--+"
		; "|  150MHz                |"
		; "|  170MHz                |"
		; "|  300MHz                |"
		; "|  CANCEL                |"
		; "+-----------[ESC]:CANCEL-+"
		db	CTXT.box,		5,1, 4, 22
		db	CTXT.prints,	5,2, "CHANGE PICO CPU CLOCK-", 0, CTXT.EOT
		db	CTXT.prints,	6,4,
		db		"150MHz",0, "170MHz",0, "300MHz",0, "CANCEL",0, CTXT.EOT
		db	CTXT.prints,	10,11, "[ESC]:CANCEL", 0, CTXT.EOT
		db	CTXT.chars,		11,2, ' ', 23
		db	CTXT.present
		db	CTXT.endc
		db	4			; 選択項目数
		db	3, 6		; カーソル原点座標 X,Y
		db	1			; デフォルト選択されている綱目番号
		dw	.item_150mhz
		dw	.item_170mhz
		dw	.item_300mhz
		dw	.item_cancel
	.item_150mhz
		ld		B, 25		; 150MHz(125+25)
		ld		A, IFCMD.SET_FREQ
		call	FUNC_CMD_TO_CTARK
		ret
	.item_170mhz
		ld		B, 45		; 170MHz(125+45)
		ld		A, IFCMD.SET_FREQ
		call	FUNC_CMD_TO_CTARK
		ret
	.item_300mhz
		ld		B, 175		; 300MHz(125+175)
		ld		A, IFCMD.SET_FREQ
		call	FUNC_CMD_TO_CTARK
		ret
	.item_cancel
		ret

;=========================================
; システムメニュー
;=========================================
FUNC_SYSTEM_MENU:
	.init
		ld		HL, .scr_system_menu
		call	CTXT_MENU
		ret
	.scr_system_menu
		; "+-MENU------------------------------+",
		; "|  ROM CARTRIDGE(Slot2) ➡ FILE     |",
		; "|  REMOVE BOOT ROM                  |",
		; "|  ROM ERASER(SIMPLE ROM CARTRIDGE) |",
		; "|  CLEAR E-PAPER                    |",
		; "|  CHANGE PICO-CPU CLOCK            |",
		; "|  INFOMATION                       |",
		; "|  CANCEL                           |",
		; "+----------------------[ESC]:CANCEL-+",
		db	CTXT.box,		4,0, 6,38
		db	CTXT.prints,	4,1,	"MENU", 0x00, CTXT.EOT
		db	CTXT.prints,	5,3 
		db		"ROM CARTRIDGE(Slot2) ", ARROW_CHAR, " FILE", 0x00
		db		"REMOVE BOOT ROM", 0x00
		db		"ROM ERASER (SIMPLE ROM CARTRIDGE)", 0x00
		db		"CLEAR E-PAPER  ", 0x00
		db		"CHANGE PICO-CPU CLOCK", 0x00
	;	db		"INFOMATION", 0x00
		db		"CANCEL", 0x00
		db		CTXT.EOT
		db	CTXT.prints,	11,24,	"[ESC]:CANCEL", 0x00, CTXT.EOT
		db	CTXT.chars,		12,1,	" ", 38
		db	CTXT.present
		db	CTXT.endc
		db	6			; 選択項目数
		db	2, 5		; カーソル原点座標 X,Y
		db	1			; デフォルト選択されている綱目番号
		dw	.item_cartridge_to_romfile
		dw	.item_remove_boot_rom
		dw	.item_rom_eraser
		dw	.item_clr_epaper
		dw	.item_cpuclock
	;	dw	.item_infomation
		dw	.item_cancel
	.item_cartridge_to_romfile
		call	START_CT_ARK.cmd_write_file
		ret
	.item_remove_boot_rom
	; 選択した起動するROMファイルの番号をPico側に伝える
		xor		A					; 0 = remove boot rom
		ld		B, A
		ld		A, IFCMD.SET_ROM
		call	FUNC_CMD_TO_CTARK
		ret	
	.item_rom_eraser
		call	FUNC_ROM_ERASER
		ret
	.item_clr_epaper
		call	FUNC_CLEAR_EPAPER_QUERY
		ret
	.item_cpuclock
		call	FUNC_CPUCLOCK
		call	UPDATE_SYSTEM_INFO	; CPUクロックの表示を更新するため
		ret
	;.item_infomation
	;	call	FUNC_INFOMATION
	;	ret
	.item_cancel
		ret

; ==========================================================
; 選択ファイルのファイル名（除く拡張子）を指定域にコピーする
; ==========================================================
; @param A カーソル位置 1～
; @param HL コピー先
; @return C 文字数
; @usereg AF,BC,DE,HL,IX
COPY_FILESPEC:
		or		A
		ret		z
	;
		push	HL	; IX <- HL
		pop		IX
		call	GET_PTR_FILERECORD
		inc		HL
		inc		HL
		inc		HL
		ld		C, 0
	.copy_loop
		ld		A, (HL)
		inc		HL
		or		A
		jr		z, .copy_end
		cp		'.'
		jr		z, .copy_end
		cp		' '
		jr		z, .copy_end
		ld		(IX+0), A
		inc		IX
		inc		C
		jr		.copy_loop
	.copy_end
		ret

; =====================================
; SCREEN 0, WIDTH40 に設定する
; =====================================
SCREEN0_40x24:
.INITXT		equ 0x006C	;; BIOS: 画面を TEXT1 モード (40*24) に初期化
.LINL40		equ 0xF3AE	;; B_INITXT: 1 行の幅
.TATNAM		equ 0xF3B3	;; B_INITXT: パターンネーム・テーブル
.TXTCGP		equ 0xF3B7	;; B_INITXT: パターンジェネレータ・テーブル
	.start
		ld		A, 40
		ld		(.LINL40), A
		ld		HL, 0x0000
		ld		(.TATNAM), HL
		ld		HL, 0x0800
		ld		(.TXTCGP), HL
		call	.INITXT
		ret

; =====================================
; lns構造の文字列を表示する
; =====================================
; HL = pointer of window structure
; 使用レジスタ AL, B, HL, IX
PRINT_LNS:
	.start
		push	HL
		pop		IX
		ld		B, (IX+0)	;; lines
		inc		IX
		ld		L, (IX+0)	;; locate
		inc		IX
		ld		H, (IX+0)
		inc		IX
	.step1
		call	B_POSIT
		inc		L
		push	HL
		
		push	IX
		pop		HL
		call	PRINT_STR
		push	HL
		pop		IX
		
		pop		HL
		djnz	.step1
		ret

; =====================================
; 0x00終端の文字列を表示する
; =====================================
; HL = 文字列へのアドレス
; 変更レジスタ HL, AF
PRINT_STR:
	.start
		ld		A, (HL)
		inc		HL
		or		A
		ret		z
		call	B_CHPUT
		jr		.start

PRINT_CHARS:
	; A = char
	; B = num
	.start
		call	B_CHPUT
		djnz	.start
		ret

; =====================================
; 16bitを四桁の１６進数文字列に変換する
; =====================================
; @param BC value
; @param HL dest ptr
HEX16TOSTR:
	.start
		xor		A
		ld		D, A

		rrc		B
		rrc		B
		rrc		B
		rrc		B
		ld		A, B
		call	TOSTR_ONECONV
		rrc		B
		rrc		B
		rrc		B
		rrc		B
		ld		A, B
		call	TOSTR_ONECONV
		rrc		C
		rrc		C
		rrc		C
		rrc		C
		ld		A, C
		call	TOSTR_ONECONV
		rrc		C
		rrc		C
		rrc		C
		rrc		C
		ld		A, C
		call	TOSTR_ONECONV
		ld		(HL), D		;; '\0'
		ret

; =====================================
; 二桁の１０進数文字列に変換する（00形式)
; =====================================
; @param A value(0-99)
; @param HL dest ptr
DEC2TOSTR:
	.start
		push	BC
		ld		BC, 0x0a00
		call	DIV8R			; C=十の位、A=一の位
		ld		B, A
		ld		A, '0'
		add		A, C
		ld		(HL), A
		inc		HL
		ld		A, '0'
		add		A, B
		ld		(HL), A
		inc		HL
		; 終端'\0'
		xor		A
		ld		(HL), A
		pop		BC
		ret

; =====================================
; 三桁の１０進数文字列に変換する（0-255→000形式)
; =====================================
; @param A value(0-255)
; @param HL dest ptr
DEC3TOSTR:
	.start
		push	BC
	;
		ld		BC, 0x6400		; A/100 → C=百の位、A=あまり（100未満の値）
		call	DIV8R
		ld		B, A
		ld		A, '0'
		add		A, C
		ld		(HL), A
		inc		HL
		ld		A, B
	;
		ld		BC, 0x0a00		; A/10 → C=十の位、A=一の位
		call	DIV8R
		ld		B, A
		ld		A, '0'
		add		A, C
		ld		(HL), A
		inc		HL
		ld		A, '0'
		add		A, B
		ld		(HL), A
		inc		HL
	; 終端'\0'
		xor		A
		ld		(HL), A
	;
		pop		BC
		ret

; =====================================
; 三桁の１０進数文字列に変換する（0-999→000形式)
; =====================================
; @param DE value(0-999) ※1000以上はNG
; @param HL dest ptr

DEC3TOSTR999:
	.start
		ld      A, D
		or      A
		jr      nz, .over999     ; 念のため（999 超えは処理しない）

		; --- 百の位を求める ---
		ld      A,E
		cp      100
		jr      c,.less100
		sub     100
		ld      B,'1'
		jr      .got_hund
	.less100
		ld      B,'0'
	.got_hund
		ld      (HL),B
		inc     HL

		; --- 十の位を求める ---
		ld      B,'0'
	.ten_loop
		cp      10
		jr      c,.ten_done
		sub     10
		inc     B
		jr      .ten_loop
	.ten_done
		ld      (HL),B
		inc     HL

		; --- 一の位 ---
		add     A,'0'
		ld      (HL),A
			jr		.terminator
		ret
	.over999
		; 999 超えは "999" を返す
		ld      (HL),'9'
		inc     HL
		ld      (HL),'9'
		inc     HL
		ld      (HL),'9'
	.terminator
		inc		HL
		xor		A
		ld      (HL),A
		ret

; =====================================
; 5桁の10進数文字列に変換する（0-65535 → 00000形式）
; =====================================
; @param DE  value (0-65535)
; @param HL  dest ptr ("00000",0 の 6バイト)
; =====================================

	DEC5TOSTR65535:
	.start
		push    HL
		; 値を HL に、出力ポインタを DE に退避
		ex      DE,HL          ; HL = value, DE = dest

		; --- 10000 の位 ---
		ld      BC,10000
		ld      A,'0'
	.dig10000
		or      A              ; C=0
		sbc     HL,BC          ; HL -= 10000
		jr      c,.done10000
		inc     A              ; digit++
		jr      .dig10000
	.done10000
		add     HL,BC          ; 負になった分を戻す → remainder
		ld      (DE),A
		inc     DE

		; --- 1000 の位 ---
		ld      BC,1000
		ld      A,'0'
	.dig1000
		or      A
		sbc     HL,BC
		jr      c,.done1000
		inc     A
		jr      .dig1000
	.done1000
		add     HL,BC
		ld      (DE),A
		inc     DE

		; --- 100 の位 ---
		ld      BC,100
		ld      A,'0'
	.dig100
		or      A
		sbc     HL,BC
		jr      c,.done100
		inc     A
		jr      .dig100
	.done100
		add     HL,BC
		ld      (DE),A
		inc     DE

		; --- 10 の位 ---
		ld      BC,10
		ld      A,'0'
	.dig10
		or      A
		sbc     HL,BC
		jr      c,.done10
		inc     A
		jr      .dig10
	.done10
		add     HL,BC
		ld      (DE),A
		inc     DE

		; --- 1 の位（ここで HL < 10 が保証されている） ---
		ld      A,L
		add     A,'0'
		ld      (DE),A
		inc     DE

		; --- 終端 ---
		xor     A
		ld      (DE),A

		; delete '0'prefix
		ld      B,4
		pop     HL
	.@@
		ld      A,(HL)
		cp      '0'
		jr      nz,.finish
		ld      (HL),' '
		inc     HL
		djnz    .@@B
	.finish
		ret


; =====================================
; 8bitを二桁の１６進数文字列に変換する
; =====================================
; @param B value
; @param HL dest ptr
; @note use DE,HL,IX
HEX8TOSTR:
	.start
		xor		A
		ld		D, A

		rrc		B
		rrc		B
		rrc		B
		rrc		B
		ld		A, B
		call	TOSTR_ONECONV
		rrc		B
		rrc		B
		rrc		B
		rrc		B
		ld		A, B
		call	TOSTR_ONECONV
		ld		(HL), D		;; '\0'
		ret

TOSTR_ONECONV:
	; A=4bit-val
	; D=0
	.start
		and		0x0f
		ld		E, A
		ld		IX, .chars
		add		IX, DE
		ld		A, (IX+0)
		ld		(HL), A
		inc		HL
		ret
	.chars
		db		"0123456789ABCDEF"

; =====================================
;キーボードバッファからキーコードを取得する
; =====================================
; B_CHGET(009FH)を使用しないので、入力待ちを行いません
; バッファにキーコードがない場合、z=ONで返る。
; キーコードが取得できた場合、A=キーコード、z=offとなります
; *変更レジスタ AF
GET_CHAR:
		B_CHSNS		equ 0x009C		;; use AF
		B_DCOMPR 	equ 0x0020		;; use AF
		W_GETPNT	equ 0xF3FA
		W_KEYBUF	equ 0xFBF0
		D_BUFEND	equ 0xFC18
	.start
		call	B_CHSNS			;;空なら即終了
		ret		z
		;
		push	HL
		ld		HL, (W_GETPNT)
		ld		A, (HL)
		push	AF
		inc		HL
		push	DE
		ld		DE, D_BUFEND
		call	B_DCOMPR
		pop		DE
		jr		nz, .step1
		ld		HL, W_KEYBUF	;;ポインタを先頭に戻す
	.step1
		ld		(W_GETPNT), HL
		pop		AF
		pop		HL
		ret


; =====================================
; PICO側へSFカードファイルのファイルリストの更新を要求する
; =====================================
UPDATE_SYSTEM_INFO:
	.start
		ld		A, IFCMD.UPDATE_INFO
		call	FUNC_CMD_TO_CTARK
		ret

; =====================================
; PICO側へSFカードファイルのファイルリストの更新を要求する
; =====================================
UPDATE_SDCARD_FILES:
	.start
		ld		A, IFCMD.UPDATE_FILELIST
		call	FUNC_CMD_TO_CTARK
		ld		HL, (MSXPICO_IF_UPDATE_FILELIST.total_num_files)
		ld		(WA_FILES.total_files), HL
		ret

CHECK_EMPTY_FILES:
	.start
		push	HL
		ld		HL, (WA_FILES.total_files)
		ld		A, H
		or		L
		pop		HL
		ret			; no files = z=on

; =====================================
; ファイルリストの表示（一列目から表示）
; =====================================
CTXT_PRINT_SDCARD_FILES:
	.start
		ld		HL, (WA_FILES.total_files)
		ld		A, H
		or		L
		jr		z, .print_nosdcard
		ld		HL, (WA_FILES.disp_top_fno)
		ld		(MSXPICO_IF_REQ_FILELIST.req_topno), HL
		ld		A, IFCMD.REQ_FILELIST		; don't care reg.B.
		call	FUNC_CMD_TO_CTARK
		ld		A, (MSXPICO_IF_REQ_FILELIST.status)
		or		A
		jr		nz, .print_files
	.print_nosdcard
		; 「SDカードにアクセスできない」メッセージの表示
		ld		HL, .nosdcard_mess
		call	CTXTF.go_scr
		jr		.finish
	.nosdcard_mess
		db	CTXT.prints, 10,6, "Could not access SD-card,", 0x00
		db					   " or No files in SD-card.", 0x00, CTXT.EOT
		db	CTXT.endc

	.print_files
		ld		HL, MSXPICO_IF_REQ_FILELIST.files
		ld		(WA_FILES.ptr),HL			; 読み出し先頭ポインタ
		ld		A, 1				; 最初のX座標
		ld		(WA_FILES.file_x),A
		ld		B, 3				; 3 列
	.colum
		push	BC
		ld		A, 2				; 最初のY座標
		ld		(WA_FILES.file_y),A
		ld		B, 18				; 18 行
	.low
		push	BC
		; 表示位置
		ld		HL, (WA_FILES.file_xy)
		inc		L
		ld		(WA_FILES.file_xy), HL
		ld		D, H
		ld		E, L
		; 1件ファイル名を表示
		ld		HL, (WA_FILES.ptr)
		push	HL
		ld		BC, 3				; MSXPICOIF_FILERECORD　内のname[]のへのオフセット
		add		HL, BC
		call	CTXTF.buff_print
		pop		HL
		; 次の1件へポインタを進める
		ld		BC, SIZE_FILERECORD	; 1件分領域のサイズ
		add		HL, BC
		ld		(WA_FILES.ptr), HL
		pop		BC
		djnz	.low
		; 次の列へ
		ld		A, (WA_FILES.file_x)
		add		A, 13				; X方向の1件の表示幅
		ld		(WA_FILES.file_x), A
		pop		BC
		djnz	.colum
	.finish
		ret



; ===========================================
; ファイル名に使用できる文字かをチェックする
; ==========================================
; @param A = char
; @return if z=on, OK.
; @usereg BC, HL, F
CHK_FILESPEC_CHAR:
	.chk_etc
		ld		BC, 76
		ld		HL, .enabled_chars
		cpir
		ret
	.enabled_chars
		db	"$&#@!%'()-{}~_"				; 14
		db	"0123456789"					; 10
		db	"abcdefghijklmnopqrstuvwxyz"	; 26
		db	"ABCDEFGHIJKLMNOPQRSTUVWXYZ"	; 26
		; ひらがな カタカナ は使えません。

; ===========================================
; 選択メニュー, RETERN:決定、ESC:キャンセル
; ==========================================
VSELECT:
; @param DE	locate
; @param B number of items
; @param A start sel_no 1-
; @return A select no 0/1~
	.init
		ld		(WA_VSELECT.home_xy), DE	; x,y
		dec		A
		ld		(WA_VSELECT.sel_no), A
		ld		D, A
		dec		B
		ld		A, B
		ld		(WA_VSELECT.max_no), A
		ld		A, D
		ld		C, CURSOR_CHAR
		call	.print_cur				; 初期位置に選択カーソルを表示
		call	CTXTF.buff_present
		call	B_KILBUF
	.wait_key
		call	GET_CHAR				; キー入力 -. A
		jr		z, .wait_key
	.chk_up
		cp		KEY_UP
		jr		nz, .chk_down
		ld		A, (WA_VSELECT.sel_no)
		or		A
		jr		z, .loop_end			;; 先頭位置なら何もしない
		ld		A, 0xff					; -1
		call	.update_cur_pos
		jr		.loop_end
	.chk_down
		cp		KEY_DOWN
		jr		nz, .chk_ret
		ld		A, (WA_VSELECT.sel_no)
		ld		HL, WA_VSELECT.max_no
		cp		(HL)
		jr		z, .loop_end			;; 末尾位置なら何もしない
		ld		A, 0x01					; +1
		call	.update_cur_pos
		jr		.loop_end
	.chk_ret
		cp		KEY_RETURN
		jr		nz, .chk_esc
		ld		A, (WA_VSELECT.sel_no)
		inc		A
		ld		(WA_VSELECT.sel_no), A
		jr		.menu_end
	.chk_esc
		cp		KEY_ESC
		jr		nz, .loop_end
		xor		A
		ld		(WA_VSELECT.sel_no), A
		jr		.menu_end
	.loop_end
		jp		.wait_key
	.menu_end
		ld		A, (WA_VSELECT.sel_no)	; 0/1～
		ret

	.update_cur_pos
	; A=step
		ld		B, A
		push	BC
		; 以前の位置のカーソルを消す
		ld		A, (WA_VSELECT.sel_no)
		ld		C, BLANK_CHAR
		call	.print_cur
		; 新しい位置にカーソル表示
		ld		A, (WA_VSELECT.sel_no)
		pop		BC
		add		A, B
		ld		(WA_VSELECT.sel_no), A
		ld		C, CURSOR_CHAR
		call	.print_cur
		call	CTXTF.buff_present
		ret

	.print_cur
	; A=sele_no
	; C=char
	; usereg DE, HL, A, C
		ld		DE, (WA_VSELECT.home_xy)
		add		A, E
		ld		E, A
		ld		A, C
		call	CTXTF.buff_put_char
		ret

; ===========================================
; 16K単位のROM ERASE（ページ0～2専用）
; ==========================================
; @param reg.A ページ番号 0～2
ROMERASEPAGE:
	.start
		rlca
		rlca
		ld		C, A
		ld		B, 4	; 4*4KB = 16KB = 1Page
	.loop1
		push	BC
		ld		A, B
		dec		A
		or		C
		rlca
		rlca
		rlca
		rlca
		ld		H, A
		call	SST39SF010A_SECTORERASE		; FlashROMの0000-FFFFFの内容を消去する
		pop		BC
		djnz	.loop1
		ret

; ===========================================
; 16K単位のROM ERASE(ページ3専用版)
; ==========================================
ROMERASEPAGE_P3:
	.start
		ld		C, 0x0c
		ld		B, 4	; 4*4KB = 16KB = 1Page
	.loop1
		push	BC
		ld		A, B
		dec		A
		or		C
		rlca
		rlca
		rlca
		rlca
		ld		H, A
		call	SST39SF010A_SECTORERASE_P3
		pop		BC
		djnz	.loop1
		ret


;================================================================================================
; ツール類（先頭位置を特定できないので、プログラムの最後でインクルードしておく）
;================================================================================================
include "tools.z80"
include "flashrom.z80"

;================================================================================================
; 作業ワークエリア
;================================================================================================
; 0x4000-0x59EE 6639 Menu-program.
; 0x59CF-0x59FF 48	 Stack area
; 0x5A00-0x5DFF 1024 CTXTB.buff
; 0x5E00-0x5EFF	256	work-ram
; 0x5F00-0x7FFF		Picoとの通信を行うためのエリアA
;
org 0x59CF
LOCALSTACK:
	.save		ds	2
	.top		ds	46
	.bottom

org 0x5A00
CTXTB:
	.buff		ds	960
	.work		ds	64

org 0x5E00
WA_FILES:
	.tmp_str		ds	15+1	; 6+1,3+1+3+1+4+2+1
	.file_xy
	.file_y			ds	1
	.file_x			ds	1
	.ptr			ds	2
	.sel_no			ds	1	; 画面内のファイル選択の番号 1 ～ 3*18
	.total_files	ds	2	; 総ファイル数 0~999
	.disp_top_fno	ds	2	; 表示先頭ファイル番号 1～

; 選択ファイルのへのアクション
WA_ACTMENU:
	.func_ptr	ds	2

; FlashROM書き込みの問い合わせ
WA_STOREROMQRY:
	.sel_no		ds	1
	.block_no	ds	1
	.read_ptr	ds	2
	.write_ptr	ds	2
	.device		dw	1

; ファイル名称の入力
WA_FNAME:
	.name		ds	8+1
	.len		ds	1	; 文字長

WA_FWRPROG:
	.block_cnt	ds	1
	.read_ptr	ds	2
	.write_ptr	ds	2

WA_VSELECT:
	.home_xy	ds	1*2	; 選択肢の原点
	.max_no		ds	1	; アイテム数-1
	.sel_no		ds	1	; 0～


;CT-ARK(Pico)との通信を行うためのエリアA
org 0x5F00
MSXPICO_IF:
	; ここにこの文字列を書き込むとPico側がコマンドを受け付けるモードになる
	; それまではタダのROMとして動作する
	.magic_word			ds	12	; "OPEN THE ARK"

	; Infomation
	; idが書き込まれると、Pico側のVer文字列が格納される
	.pico_side_version	ds	5+1	; "xx.xx" + \0

	; idが書き込まれると、Picoの動作周波数[Mhz]が文字列で格納される ex)"125"
	.pico_clock_mhz		ds	5+1	; "(xxx)" + \0

	; 起動設定されているROMファイル名がPico側から格納される
	.boot_rom_name		ds	13	; "xxxxxxxx.xxx\0" (8+1+3+1)

	;Command
	; .cmd にコマンドを書く前に 0 にしておくこと。.cmdにコマンドを書き込んだ後、
	; ここに.cmdに書き込んだ値と同じ値が格納される
	.cmd_res			ds	1	; 
	;
	.cmds equ $

;----------
org MSXPICO_IF.cmds
MSXPICO_IF_BASE:
	.code					ds	1		; IFCMD.*
	.cmd_value				ds	1		; 
	.end					equ $

org MSXPICO_IF.cmds
MSXPICO_IF_UPDATE_FILELIST:
	.code					ds	1		; IFCMD.REQ_FILELIST
	.action					ds	1		; 0固定
	;以下はpico->msx
	.status					ds	1		; 0:no sd card, !0:files
	.total_num_files		ds	2		; 総ファイル数
	.end					equ $

org MSXPICO_IF.cmds
MSXPICO_IF_REQ_FILELIST:
	.code					ds	1		; IFCMD.REQ_FILELIST
	.action					ds	1		; 不使用
	.req_topno				ds	2		; 先頭ファイル番号
	;以下はpico->msx
	.status					ds	1		; 0:no sd card, !0:files
	.padding1				ds	1		; 不使用
	.padding2				ds	1		; 不使用
	.files					ds	SIZE_FILERECORD*3*18	; MSXPICOIF_FILERECORD[3列*18行]
	.end					equ $

org MSXPICO_IF.cmds
MSXPICO_IF_STR_SET_ROM:
	.code					ds	1		; IFCMD.SET_ROM
	.file_no				ds	1		; 選択ファイル番号 0:選択無し 1～:ROMファイル番号
	.boot_rom_type			ds	1		; ROM TYPE
	.end					equ $

org MSXPICO_IF.cmds
MSXPICO_IF_STR_DEL_ROMFILE:
	.code					ds	1		; IFCMD.DEL_ROMFILE
	.file_no				ds	1		; 削除したいROMファイル番号 1～
	.end					equ $

org MSXPICO_IF.cmds
MSXPICO_IF_STR_WR_FILE:
	.BLOCK_SIZE				equ	0x2000
	.code					ds	1			; IFCMD.WR_FILE
	.block_no				ds	1			; 0x2000サイズ単位のブロック番号 0～
	.cmd_fwr_fspec			ds	8+1			; 保存ファイル名（拡張子無し）
	.block_data				ds	.BLOCK_SIZE	; ブロックデータ
	.end					equ $

org MSXPICO_IF.cmds
MSXPICO_IF_STR_BAS2ROM:
	.code					ds	1		; IFCMD.BAS2ROM
	.file_no				ds	1		; ROMファイルに変換したいBASファイルの番号 1～
	.cmd_fwr_fspec			ds	8+1		; 保存ファイル名（拡張子無し）
	.end					equ $

org MSXPICO_IF.cmds
MSXPICO_IF_STR_STORE_ROM:
	.BLOCK_SIZE				equ	0x2000
	.code					ds	1			; IFCMD.STORE_ROM
	.file_no				ds	1			; ROMへ書き込みたいROMファイルの番号 1～
	.block_no				ds	1			; 0x2000サイズ単位のブロック番号 0～
	;以下はpico->msx
	.err_no					ds	1			; 0:ファイル読み込みOK、1:何らかの理由で読み込みできず
	.str_num_total_block	ds	1			; ファイル全体のブロック数
	.str_block				ds	1			; 0:要求されたブロックは無し、1:有り
	.str_block_data			ds	.BLOCK_SIZE	; ブロックデータ
	.end					equ $

org MSXPICO_IF.cmds
MSXPICO_IF_STR_SET_FREQ:
	.code					ds	1		; IFCMD.SET_FREQ
	.freq_mhz				ds	1		; 周波数MHz 125～300MHz
	.end					equ $

org MSXPICO_IF.cmds
MSXPICO_IF_STR_CLEAR_EPAPER:
	.code					ds	1		; IFCMD.CLEAR_E_PAPER
	.cmd_value				ds	1		; no use
	.end					equ $


