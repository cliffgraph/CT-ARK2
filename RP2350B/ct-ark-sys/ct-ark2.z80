		db	CTXT.prints,	11,15, "CANCEL", 0, "OK", 0, CTXT.EOT
		db	CTXT.prints,	13,22, "[ESC]:CANCEL", 0, CTXT.EOT
		db	CTXT.chars,		14,4, ' ', 33
