		;"+-------------------------------+ "
		;"|                               | "
		;"|  *** Process completed!! ***  | "
		;"|                               | "
		;"+-------------------Hit any key-+ "
		db	CTXT.box,		6,5, 3,30
		db	CTXT.prints,	8,7, "**** Process completed. ****",0, CTXT.EOT
		db	CTXT.prints,	10,24, "Hit any key",0, CTXT.EOT 
		db	CTXT.chars,		11,6, ' ', 32
		db	CTXT.present
		db	CTXT.endc

